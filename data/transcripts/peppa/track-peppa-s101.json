{
  "trackId": "track-peppa-s101",
  "contentId": "peppa-1",
  "mediaType": "audio",
  "lines": [
    {
      "lineId": "peppa-s101-1a",
      "text": "Narrator: It is raining today.",
      "startMs": 590,
      "endMs": 4060
    },
    {
      "lineId": "peppa-s101-1b",
      "text": "So Peppa and George cannot play outside.",
      "startMs": 7970,
      "endMs": 15080
    },
    {
      "lineId": "peppa-s101-2",
      "text": "Peppa: Daddy, it's stopped raining.",
      "startMs": 16460,
      "endMs": 18838
    },
    {
      "lineId": "peppa-s101-3",
      "text": "Peppa: Can we go out to play?",
      "startMs": 19128,
      "endMs": 23598
    },
    {
      "lineId": "peppa-s101-4",
      "text": "Daddy Pig: All right, run along you two.",
      "startMs": 26357,
      "endMs": 28153
    },
    {
      "lineId": "peppa-s101-5",
      "text": "Narrator: Peppa loves jumping in muddy puddles.",
      "startMs": 27233,
      "endMs": 29813
    },
    {
      "lineId": "peppa-s101-6",
      "text": "Peppa: I love muddy puddles.",
      "startMs": 35811,
      "endMs": 38721
    },
    {
      "lineId": "peppa-s101-7a",
      "text": "Mummy Pig: Peppa! If you jump in muddy puddles,",
      "startMs": 39495,
      "endMs": 48125
    },
    {
      "lineId": "peppa-s101-7b",
      "text": "you must wear your boots.",
      "startMs": 46900,
      "endMs": 50440
    },
    {
      "lineId": "peppa-s101-8",
      "text": "Peppa: Sorry, Mummy.",
      "startMs": 54984,
      "endMs": 55474
    },
    {
      "lineId": "peppa-s101-9",
      "text": "Narrator: George likes to jump in muddy puddles, too.",
      "startMs": 56876,
      "endMs": 64446
    },
    {
      "lineId": "peppa-s101-10a",
      "text": "Peppa: George.",
      "startMs": 66506,
      "endMs": 67066
    },
    {
      "lineId": "peppa-s101-10b",
      "text": "If you jump in muddy puddles,",
      "startMs": 67610,
      "endMs": 73000
    },
    {
      "lineId": "peppa-s101-10c",
      "text": "you must wear your boots.",
      "startMs": 72330,
      "endMs": 74920
    },
    {
      "lineId": "peppa-s101-11",
      "text": "Narrator: Peppa likes to look after her little brother, George.",
      "startMs": 74790,
      "endMs": 79320
    },
    {
      "lineId": "peppa-s101-12",
      "text": "Peppa: George, let's find some more puddles.",
      "startMs": 86262,
      "endMs": 92552
    },
    {
      "lineId": "peppa-s101-13",
      "text": "Narrator: Peppa and George are having a lot of fun.",
      "startMs": 94033,
      "endMs": 100723
    },
    {
      "lineId": "peppa-s101-14a",
      "text": "Narrator: Peppa has found a little puddle.",
      "startMs": 101691,
      "endMs": 104191
    },
    {
      "lineId": "peppa-s101-14b",
      "text": "George has found a big puddle.",
      "startMs": 107500,
      "endMs": 113540
    },
    {
      "lineId": "peppa-s101-15",
      "text": "Peppa: Look, George. There's a really big puddle.",
      "startMs": 114905,
      "endMs": 116355
    },
    {
      "lineId": "peppa-s101-16",
      "text": "Narrator: George wants to jump into the big puddle first.",
      "startMs": 119063,
      "endMs": 130963
    },
    {
      "lineId": "peppa-s101-17a",
      "text": "Peppa: Stop, George.",
      "startMs": 130883,
      "endMs": 133653
    },
    {
      "lineId": "peppa-s101-17b",
      "text": "I must check if it is safe for you.",
      "startMs": 132830,
      "endMs": 139032
    },
    {
      "lineId": "peppa-s101-18a",
      "text": "Peppa: Good. It is safe for you.",
      "startMs": 138142,
      "endMs": 142622
    },
    {
      "lineId": "peppa-s101-18b",
      "text": "Sorry, George. It is only mud.",
      "startMs": 143980,
      "endMs": 149040
    },
    {
      "lineId": "peppa-s101-19",
      "text": "Narrator: Peppa and George love jumping in muddy puddles.",
      "startMs": 155589,
      "endMs": 159909
    },
    {
      "lineId": "peppa-s101-20",
      "text": "Peppa: Come on, George. Let's go and show Daddy.",
      "startMs": 161274,
      "endMs": 167124
    },
    {
      "lineId": "peppa-s101-21",
      "text": "Daddy Pig: Goodness me.",
      "startMs": 169191,
      "endMs": 171191
    },
    {
      "lineId": "peppa-s101-22a",
      "text": "Peppa: Daddy, Daddy,",
      "startMs": 171871,
      "endMs": 176571
    },
    {
      "lineId": "peppa-s101-22b",
      "text": "guess what we've been doing.",
      "startMs": 175000,
      "endMs": 181524
    },
    {
      "lineId": "peppa-s101-23a",
      "text": "Daddy Pig: Let me think.",
      "startMs": 179924,
      "endMs": 185000
    },
    {
      "lineId": "peppa-s101-23b",
      "text": "Have you been watching television?",
      "startMs": 183400,
      "endMs": 188040
    },
    {
      "lineId": "peppa-s101-24",
      "text": "Peppa: No, no, Daddy.",
      "startMs": 190501,
      "endMs": 193891
    },
    {
      "lineId": "peppa-s101-25",
      "text": "Daddy Pig: Have you just had a bath?",
      "startMs": 193462,
      "endMs": 196372
    },
    {
      "lineId": "peppa-s101-26",
      "text": "Peppa: No, no.",
      "startMs": 199989,
      "endMs": 200949
    },
    {
      "lineId": "peppa-s101-27a",
      "text": "Daddy Pig: I know.",
      "startMs": 201720,
      "endMs": 204230
    },
    {
      "lineId": "peppa-s101-27b",
      "text": "You've been jumping in muddy puddles.",
      "startMs": 203900,
      "endMs": 209210
    },
    {
      "lineId": "peppa-s101-28a",
      "text": "Peppa: Yes, yes, Daddy.",
      "startMs": 210884,
      "endMs": 213614
    },
    {
      "lineId": "peppa-s101-28b",
      "text": "We've been jumping in muddy puddles.",
      "startMs": 215290,
      "endMs": 217500
    },
    {
      "lineId": "peppa-s101-29a",
      "text": "Daddy Pig: Ho ho.",
      "startMs": 220555,
      "endMs": 222415
    },
    {
      "lineId": "peppa-s101-29b",
      "text": "And look at the mess you are in.",
      "startMs": 223670,
      "endMs": 230020
    },
    {
      "lineId": "peppa-s101-30",
      "text": "Peppa: Ooh.",
      "startMs": 229083,
      "endMs": 229363
    },
    {
      "lineId": "peppa-s101-31a",
      "text": "Daddy Pig: Oh well, it's only mud.",
      "startMs": 230575,
      "endMs": 234615
    },
    {
      "lineId": "peppa-s101-31b",
      "text": "Let's clean up quickly",
      "startMs": 235300,
      "endMs": 240910
    },
    {
      "lineId": "peppa-s101-31c",
      "text": "before Mummy sees the mess.",
      "startMs": 239800,
      "endMs": 246090
    },
    {
      "lineId": "peppa-s101-32a",
      "text": "Peppa: Daddy, when we have cleaned up,",
      "startMs": 244515,
      "endMs": 248035
    },
    {
      "lineId": "peppa-s101-32b",
      "text": "will you and Mummy come and play too?",
      "startMs": 250800,
      "endMs": 256810
    },
    {
      "lineId": "peppa-s101-33",
      "text": "Daddy Pig: Yes, we can all play in the garden.",
      "startMs": 257106,
      "endMs": 266006
    },
    {
      "lineId": "peppa-s101-34a",
      "text": "Narrator: Peppa and George are wearing their boots.",
      "startMs": 265586,
      "endMs": 268476
    },
    {
      "lineId": "peppa-s101-34b",
      "text": "Mummy and Daddy are wearing their boots.",
      "startMs": 273950,
      "endMs": 279740
    },
    {
      "lineId": "peppa-s101-35a",
      "text": "Narrator: Peppa loves jumping up and down in muddy puddles.",
      "startMs": 279687,
      "endMs": 290000
    },
    {
      "lineId": "peppa-s101-35b",
      "text": "Everyone loves jumping up and down in muddy puddles.",
      "startMs": 288400,
      "endMs": 299695
    },
    {
      "lineId": "peppa-s101-36a",
      "text": "Mummy Pig: Oh, Daddy Pig,",
      "startMs": 298095,
      "endMs": 300265
    },
    {
      "lineId": "peppa-s101-36b",
      "text": "look at the mess you're in.",
      "startMs": 301900,
      "endMs": 307506
    },
    {
      "lineId": "peppa-s101-37",
      "text": "Peppa: It's only mud.",
      "startMs": 307506,
      "endMs": 310957
    }
  ]
}