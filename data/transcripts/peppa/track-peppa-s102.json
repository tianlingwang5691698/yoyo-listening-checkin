{
  "trackId": "track-peppa-s102",
  "contentId": "peppa-2",
  "mediaType": "audio",
  "lines": [
    {
      "lineId": "peppa-s102-1",
      "text": "Narrator: George's favourite toy is Mr Dinosaur.",
      "startMs": 1110,
      "endMs": 9330
    },
    {
      "lineId": "peppa-s102-2",
      "text": "George: Dinosaur!",
      "startMs": 8206,
      "endMs": 10726
    },
    {
      "lineId": "peppa-s102-3",
      "text": "Narrator: George loves Mr Dinosaur.",
      "startMs": 9622,
      "endMs": 16352
    },
    {
      "lineId": "peppa-s102-4",
      "text": "George: Grrr!",
      "startMs": 15286,
      "endMs": 16096
    },
    {
      "lineId": "peppa-s102-5",
      "text": "Narrator: Sometimes, George likes to scare Peppa with Mr Dinosaur.",
      "startMs": 19742,
      "endMs": 30512
    },
    {
      "lineId": "peppa-s102-6",
      "text": "George: Grrr!",
      "startMs": 29446,
      "endMs": 30516
    },
    {
      "lineId": "peppa-s102-7",
      "text": "Peppa: Eek! Too scary.",
      "startMs": 30962,
      "endMs": 32582
    },
    {
      "lineId": "peppa-s102-8",
      "text": "Narrator: At suppertime, Mr Dinosaur sits next to George.",
      "startMs": 35110,
      "endMs": 40820
    },
    {
      "lineId": "peppa-s102-9",
      "text": "Mummy Pig: I beg your pardon.",
      "startMs": 46498,
      "endMs": 51598
    },
    {
      "lineId": "peppa-s102-10",
      "text": "Mummy Pig: Was that you George, or was it Mr Dinosaur?",
      "startMs": 50850,
      "endMs": 53490
    },
    {
      "lineId": "peppa-s102-11",
      "text": "George: Dinosaur!",
      "startMs": 56813,
      "endMs": 57273
    },
    {
      "lineId": "peppa-s102-12",
      "text": "Narrator: At bath time, George shares his bath with Mr Dinosaur.",
      "startMs": 58393,
      "endMs": 65073
    },
    {
      "lineId": "peppa-s102-13",
      "text": "George: Grrr!",
      "startMs": 66508,
      "endMs": 67278
    },
    {
      "lineId": "peppa-s102-14",
      "text": "Mummy Pig: Good night, Peppa.",
      "startMs": 66488,
      "endMs": 68078
    },
    {
      "lineId": "peppa-s102-15",
      "text": "Peppa: Good night, Mummy.",
      "startMs": 68222,
      "endMs": 71352
    },
    {
      "lineId": "peppa-s102-16",
      "text": "Mummy Pig: Good night, George.",
      "startMs": 70406,
      "endMs": 72636
    },
    {
      "lineId": "peppa-s102-17",
      "text": "Mummy Pig: And good night, Mr Dinosaur.",
      "startMs": 72470,
      "endMs": 77060
    },
    {
      "lineId": "peppa-s102-18",
      "text": "George: Grrr!",
      "startMs": 76557,
      "endMs": 77547
    },
    {
      "lineId": "peppa-s102-19",
      "text": "Narrator: When George goes to bed, Mr Dinosaur is tucked up with him.",
      "startMs": 77137,
      "endMs": 81217
    },
    {
      "lineId": "peppa-s102-20",
      "text": "Narrator: George's favourite game is throwing Mr Dinosaur up in the air...",
      "startMs": 82260,
      "endMs": 89370
    },
    {
      "lineId": "peppa-s102-21",
      "text": "George: Whee!",
      "startMs": 89999,
      "endMs": 90389
    },
    {
      "lineId": "peppa-s102-22",
      "text": "Narrator: ...and catching him when he falls back down.",
      "startMs": 91279,
      "endMs": 96329
    },
    {
      "lineId": "peppa-s102-23",
      "text": "George: Whee!",
      "startMs": 97937,
      "endMs": 98757
    },
    {
      "lineId": "peppa-s102-24",
      "text": "Narrator: Peppa and Daddy Pig are playing draughts.",
      "startMs": 98027,
      "endMs": 103527
    },
    {
      "lineId": "peppa-s102-25",
      "text": "Peppa: I win, Daddy.",
      "startMs": 103272,
      "endMs": 105722
    },
    {
      "lineId": "peppa-s102-26",
      "text": "Daddy Pig: Oh. Well done, Peppa.",
      "startMs": 105103,
      "endMs": 108503
    },
    {
      "lineId": "peppa-s102-27",
      "text": "George: Whaaaaaaaa!",
      "startMs": 108007,
      "endMs": 109490
    },
    {
      "lineId": "peppa-s102-28",
      "text": "Daddy Pig: George?",
      "startMs": 108530,
      "endMs": 109150
    },
    {
      "lineId": "peppa-s102-29",
      "text": "George: Whaaaaaaaa!",
      "startMs": 106720,
      "endMs": 109090
    },
    {
      "lineId": "peppa-s102-30",
      "text": "Mummy Pig: George, what's the matter?",
      "startMs": 108040,
      "endMs": 110910
    },
    {
      "lineId": "peppa-s102-31",
      "text": "George: Dinosaur.",
      "startMs": 111532,
      "endMs": 111812
    },
    {
      "lineId": "peppa-s102-32",
      "text": "Daddy Pig: George, have you lost Mr Dinosaur?",
      "startMs": 112312,
      "endMs": 116802
    },
    {
      "lineId": "peppa-s102-33",
      "text": "Narrator: George has lost Mr Dinosaur.",
      "startMs": 116575,
      "endMs": 119925
    },
    {
      "lineId": "peppa-s102-34",
      "text": "Mummy Pig: Don't worry, George. We'll find Mr Dinosaur.",
      "startMs": 121952,
      "endMs": 126492
    },
    {
      "lineId": "peppa-s102-35",
      "text": "Daddy Pig: It's a job for a detective.",
      "startMs": 125550,
      "endMs": 129770
    },
    {
      "lineId": "peppa-s102-36",
      "text": "Peppa: Daddy, what is a detective?",
      "startMs": 130623,
      "endMs": 133903
    },
    {
      "lineId": "peppa-s102-37",
      "text": "Daddy Pig: A detective is a very important person who is good at finding things.",
      "startMs": 133720,
      "endMs": 139970
    },
    {
      "lineId": "peppa-s102-38",
      "text": "Peppa: Me! Me! I'm good at finding things.",
      "startMs": 144031,
      "endMs": 147231
    },
    {
      "lineId": "peppa-s102-39",
      "text": "Daddy Pig: All right. Peppa is the detective.",
      "startMs": 145920,
      "endMs": 149500
    },
    {
      "lineId": "peppa-s102-40",
      "text": "Peppa: George. I am the detective. I will help you find Mr Dinosaur.",
      "startMs": 150356,
      "endMs": 157376
    },
    {
      "lineId": "peppa-s102-41",
      "text": "Mummy Pig: Maybe the detective should ask George some simple questions.",
      "startMs": 158227,
      "endMs": 164917
    },
    {
      "lineId": "peppa-s102-42",
      "text": "Peppa: George, where's Mr Dinosaur?",
      "startMs": 164415,
      "endMs": 167435
    },
    {
      "lineId": "peppa-s102-43",
      "text": "George: Whaaaaaaaa!",
      "startMs": 166409,
      "endMs": 168479
    },
    {
      "lineId": "peppa-s102-44",
      "text": "Narrator: George does not know where Mr Dinosaur is.",
      "startMs": 167689,
      "endMs": 171689
    },
    {
      "lineId": "peppa-s102-45",
      "text": "Daddy Pig: The detective could try and guess where Mr Dinosaur might be.",
      "startMs": 174876,
      "endMs": 181366
    },
    {
      "lineId": "peppa-s102-46",
      "text": "Peppa: I know. I know where he is.",
      "startMs": 180496,
      "endMs": 184436
    },
    {
      "lineId": "peppa-s102-47",
      "text": "Peppa: George always has Mr Dinosaur with him in the bath.",
      "startMs": 186383,
      "endMs": 191913
    },
    {
      "lineId": "peppa-s102-48",
      "text": "Peppa: So Mr Dinosaur is in the bath.",
      "startMs": 191402,
      "endMs": 196252
    },
    {
      "lineId": "peppa-s102-49",
      "text": "Narrator: Mr Dinosaur is not in the bath.",
      "startMs": 194310,
      "endMs": 197420
    },
    {
      "lineId": "peppa-s102-50",
      "text": "Peppa: Oh. I know. I know where Mr Dinosaur is.",
      "startMs": 199058,
      "endMs": 204352
    },
    {
      "lineId": "peppa-s102-51",
      "text": "Peppa: George always has Mr Dinosaur in his bed at night.",
      "startMs": 203602,
      "endMs": 207762
    },
    {
      "lineId": "peppa-s102-52",
      "text": "Peppa: So that's where he is.",
      "startMs": 208768,
      "endMs": 210488
    },
    {
      "lineId": "peppa-s102-53",
      "text": "Narrator: Mr Dinosaur is not in George's bed.",
      "startMs": 211441,
      "endMs": 216371
    },
    {
      "lineId": "peppa-s102-54",
      "text": "Peppa: Oh.",
      "startMs": 216029,
      "endMs": 216359
    },
    {
      "lineId": "peppa-s102-55",
      "text": "Mummy Pig: Maybe we should try the garden.",
      "startMs": 216509,
      "endMs": 221025
    },
    {
      "lineId": "peppa-s102-56",
      "text": "Peppa: Yes, the garden. I was going to say that.",
      "startMs": 219885,
      "endMs": 225965
    },
    {
      "lineId": "peppa-s102-57",
      "text": "Peppa: Where is Mr Dinosaur?",
      "startMs": 224799,
      "endMs": 228209
    },
    {
      "lineId": "peppa-s102-58",
      "text": "Narrator: Mr Dinosaur is very hard to find.",
      "startMs": 227009,
      "endMs": 231399
    },
    {
      "lineId": "peppa-s102-59",
      "text": "Peppa: Oh. Mr Dinosaur isn't anywhere.",
      "startMs": 228550,
      "endMs": 231360
    },
    {
      "lineId": "peppa-s102-60",
      "text": "Daddy Pig: George? You do love to throw Mr Dinosaur in the air.",
      "startMs": 231733,
      "endMs": 240002
    },
    {
      "lineId": "peppa-s102-61",
      "text": "Daddy Pig: I wonder if this time you threw Mr Dinosaur just a bit too high.",
      "startMs": 239102,
      "endMs": 246062
    },
    {
      "lineId": "peppa-s102-62",
      "text": "Peppa: There he is. There he is. I saw him first.",
      "startMs": 249929,
      "endMs": 254019
    },
    {
      "lineId": "peppa-s102-63",
      "text": "Daddy Pig: Well done, Peppa.",
      "startMs": 254395,
      "endMs": 256635
    },
    {
      "lineId": "peppa-s102-64",
      "text": "Daddy Pig: You really are a very good detective.",
      "startMs": 256273,
      "endMs": 261533
    },
    {
      "lineId": "peppa-s102-65",
      "text": "George: Dinosaur. Grrr!",
      "startMs": 260651,
      "endMs": 263136
    },
    {
      "lineId": "peppa-s102-66",
      "text": "Narrator: George is so happy to have Mr Dinosaur back again.",
      "startMs": 261936,
      "endMs": 269526
    },
    {
      "lineId": "peppa-s102-67",
      "text": "George: Whee!",
      "startMs": 270252,
      "endMs": 270592
    },
    {
      "lineId": "peppa-s102-68",
      "text": "Daddy Pig: Maybe it isn't a good idea to play with dinosaurs near trees.",
      "startMs": 269562,
      "endMs": 277602
    },
    {
      "lineId": "peppa-s102-69",
      "text": "George: Dinosaur!",
      "startMs": 277274,
      "endMs": 277634
    }
  ]
}