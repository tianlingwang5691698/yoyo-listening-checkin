.home-titlebar {
  padding: 76rpx 20rpx 42rpx;
  text-align: center;
}

.home-brand {
  font-size: 42rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.home-subtitle {
  margin-top: 12rpx;
}

.mode-notice {
  margin: 0 20rpx 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.35;
  text-align: center;
  font-weight: 700;
}

.mode-reminder {
  margin: 0 20rpx 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(180, 94, 64, 0.09);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-reminder-actions {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mode-reminder-action {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 23rpx;
  line-height: 60rpx;
  font-weight: 700;
}

.mode-reminder-action.is-primary {
  background: rgba(180, 94, 64, 0.12);
  color: #b45e40;
}

.mode-reminder-action::after {
  border: none;
}

.program-swiper {
  width: 100%;
  height: 520rpx;
}

.program-slide {
  height: 456rpx;
  margin: 0 10rpx;
  padding: 34rpx 30rpx;
  background: rgba(255, 255, 255, 0.86);
}

.program-slide.is-disabled {
  opacity: 0.5;
}

.slide-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.slide-name {
  color: var(--text-strong);
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.slide-state {
  flex-shrink: 0;
  color: var(--accent-deep);
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.slide-state.is-done,
.slide-state.is-waiting {
  color: var(--text-muted);
  font-size: 22rpx;
}

.slide-title {
  margin-top: 44rpx;
  color: var(--text-strong);
  font-size: 42rpx;
  line-height: 1.22;
  font-weight: 700;
}

.slide-meta {
  margin-top: 16rpx;
}

.slide-line {
  width: 100%;
  height: 2rpx;
  margin-top: 34rpx;
  background: rgba(37, 35, 33, 0.08);
}

.slide-task {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid rgba(37, 35, 33, 0.08);
}

.slide-task-title {
  color: var(--text-main);
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 600;
}

.slide-task-meta {
  margin-top: 6rpx;
}

.slide-task-state {
  flex-shrink: 0;
  min-width: 64rpx;
  color: var(--accent-deep);
  text-align: right;
  font-size: 23rpx;
  font-weight: 700;
}

.slide-task.is-disabled {
  opacity: 0.48;
}
