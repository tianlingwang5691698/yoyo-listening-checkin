.hero {
  padding: 36rpx 32rpx;
  background:
    radial-gradient(circle at 18% 22%, rgba(255, 233, 189, 0.92), transparent 22%),
    linear-gradient(135deg, #fff7e2 0%, #fff0de 52%, #ffe3d1 100%);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #ad7f55;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #2f241f;
}

.hero-copy {
  margin-top: 16rpx;
  max-width: 430rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7f6d61;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.sync-debug-line {
  margin-top: 8rpx;
  word-break: break-all;
}

.avatar-badge {
  width: 108rpx;
  height: 108rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  color: #7a5a48;
  font-size: 34rpx;
  font-weight: 800;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 30rpx;
}

.hero-stat {
  padding: 22rpx 0;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.64);
}

.hero-stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #2f241f;
}

.hero-stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c7e72;
}

.assignment {
  margin-top: 24rpx;
  padding: 30rpx;
}

.assignment-cover {
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  min-height: 280rpx;
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  box-shadow: 0 22rpx 56rpx rgba(141, 102, 76, 0.14);
}

.tone-sunrise {
  background: linear-gradient(135deg, #ffd79e 0%, #ffc1ab 100%);
}

.tone-peach {
  background: linear-gradient(135deg, #ffe8d7 0%, #ffbfa5 100%);
}

.tone-berry {
  background: linear-gradient(135deg, #ffd0cb 0%, #ff9f8a 100%);
}

.tone-meadow {
  background: linear-gradient(135deg, #d5f1d7 0%, #a0ddac 100%);
}

.tone-mint {
  background: linear-gradient(135deg, #d7f4ec 0%, #9bdcc9 100%);
}

.cover-variant-peppa {
  background:
    radial-gradient(circle at 16% 18%, rgba(255, 248, 232, 0.75), transparent 24%),
    linear-gradient(145deg, #ffe4c4 0%, #ffc4b3 52%, #ffad8f 100%);
}

.cover-variant-unlock {
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.76), transparent 24%),
    linear-gradient(145deg, #f6efe8 0%, #ecd8c9 48%, #d3c0b5 100%);
}

.cover-variant-song {
  background:
    radial-gradient(circle at 16% 20%, rgba(255, 255, 255, 0.78), transparent 24%),
    linear-gradient(145deg, #eef7f3 0%, #d7efe5 48%, #bddccc 100%);
}

.cover-glow {
  position: absolute;
  right: -42rpx;
  top: -36rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.26);
}

.cover-orbit {
  position: absolute;
  right: 66rpx;
  bottom: 28rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
}

.cover-text,
.cover-ring {
  position: relative;
  z-index: 1;
}

.cover-label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(47, 36, 31, 0.52);
  font-weight: 700;
}

.cover-title {
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1.14;
  font-weight: 800;
  color: #2f241f;
}

.cover-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(47, 36, 31, 0.72);
}

.cover-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 251, 245, 0.74);
  color: #2f241f;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: inset 0 0 0 12rpx rgba(255, 255, 255, 0.18);
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 22rpx 0 26rpx;
}

.flow-card {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: #fff9f3;
}

.reward-card {
  display: flex;
  gap: 18rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #fff7eb 0%, #fff2e4 100%);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.4);
}

.reward-peppa {
  background: linear-gradient(135deg, #fff7eb 0%, #fff0e2 100%);
}

.reward-peppa .reward-badge {
  background: #ffeddc;
  color: #d56f4c;
}

.reward-unlock {
  background: linear-gradient(135deg, #f7f3ee 0%, #efe7df 100%);
}

.reward-unlock .reward-badge {
  background: #e7ddd3;
  color: #7f6a5d;
}

.reward-song {
  background: linear-gradient(135deg, #f1fbf6 0%, #e6f7ef 100%);
}

.reward-song .reward-badge {
  background: #daf2e7;
  color: #4fa684;
}

.reward-badge {
  flex-shrink: 0;
  min-width: 136rpx;
  padding: 16rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #ffeddc;
  color: #d56f4c;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.reward-body {
  min-width: 0;
}

.reward-title {
  font-size: 25rpx;
  font-weight: 800;
  color: #2f241f;
}

.reward-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8c7e72;
}

.flow-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #2f241f;
}

.flow-copy {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #8c7e72;
}

.flow-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.flow-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f4efea;
  color: #8c7e72;
  font-size: 22rpx;
}

.flow-pill.is-on {
  background: #edf9ef;
  color: #5f9d66;
}

.daily-task-list {
  margin-top: 14rpx;
}

.daily-task-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(84, 57, 45, 0.08);
}

.daily-task-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.daily-task-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f241f;
}

.daily-task-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8c7e72;
}

.daily-task-status {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f4efea;
  color: #8c7e72;
  font-size: 22rpx;
}

.daily-task-status.is-on {
  background: #fff1e3;
  color: #d96a45;
}

.keyword-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff5ea;
  color: #9a6d4e;
  font-size: 22rpx;
}

.unit-strip {
  margin-top: 30rpx;
}

.strip-link {
  color: #ef7c55;
  font-size: 24rpx;
}

.unit-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.unit-row {
  display: inline-flex;
  gap: 18rpx;
  padding-bottom: 8rpx;
}

.unit-card {
  width: 232rpx;
  padding: 24rpx;
}

.unit-theme {
  font-size: 20rpx;
  color: #ad7f55;
}

.unit-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.unit-progress {
  margin-top: 20rpx;
  color: #74b87c;
  font-size: 24rpx;
  font-weight: 700;
}

.recent-block {
  margin-top: 26rpx;
  padding-bottom: 20rpx;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx;
  margin-top: 18rpx;
}

.recent-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f241f;
}

.recent-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #8c7e72;
}

.recent-status {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.is-done {
  background: #edf9ef;
  color: #5f9d66;
}

.is-ready {
  background: #fff2e7;
  color: #d96a45;
}

.is-locked {
  background: #f4efea;
  color: #8c7e72;
}
