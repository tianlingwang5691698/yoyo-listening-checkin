.home-titlebar {
  padding: 72rpx 20rpx 22rpx;
  text-align: center;
}

.home-time {
  color: var(--text-strong);
  font-size: 32rpx;
  font-weight: 800;
}

.home-subtitle {
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.primary-checkin {
  padding: 34rpx 28rpx 30rpx;
  background: rgba(255, 255, 255, 0.86);
}

.primary-label {
  color: var(--text-muted);
  font-size: 23rpx;
  font-weight: 800;
}

.primary-title {
  margin-top: 16rpx;
  color: var(--text-strong);
  font-size: 42rpx;
  line-height: 1.22;
  font-weight: 900;
}

.primary-meta {
  margin-top: 16rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  font-weight: 700;
}

.primary-progress {
  margin-top: 24rpx;
  background: #ece8e1;
}

.primary-button {
  width: 520rpx;
  max-width: 100%;
  min-height: 86rpx;
  margin: 28rpx auto 0;
  font-size: 28rpx;
}

.minimal-program {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.82);
}

.program-name {
  color: var(--text-strong);
  font-size: 34rpx;
  font-weight: 900;
}

.program-line {
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: 23rpx;
}

.minimal-task {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(37, 35, 33, 0.08);
}

.minimal-task-title {
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
}

.minimal-task-meta {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.minimal-task-action {
  flex-shrink: 0;
  min-width: 88rpx;
  color: var(--accent-deep);
  text-align: right;
  font-size: 23rpx;
  font-weight: 900;
}

.minimal-task.is-disabled {
  opacity: 0.48;
}
