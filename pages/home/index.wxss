.home-titlebar {
  padding: 76rpx 20rpx 34rpx;
  text-align: center;
}

.home-brand {
  font-size: 42rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.home-subtitle {
  margin-top: 12rpx;
}

.minimal-program {
  margin-top: 18rpx;
  padding: 30rpx 28rpx;
  background: rgba(255, 255, 255, 0.82);
}

.minimal-program:first-of-type {
  margin-top: 0;
}

.minimal-program.is-disabled {
  opacity: 0.48;
}

.program-name {
  color: var(--text-strong);
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.program-line {
  margin-top: 12rpx;
}

.program-state {
  flex-shrink: 0;
  min-width: 46rpx;
  color: var(--accent-deep);
  text-align: right;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
}

.program-state.is-done {
  color: var(--text-muted);
  font-size: 22rpx;
}

.minimal-task {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(37, 35, 33, 0.08);
}

.minimal-task-title {
  color: var(--text-main);
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 600;
}

.minimal-task-meta {
  margin-top: 8rpx;
}

.minimal-task-action {
  flex-shrink: 0;
  min-width: 88rpx;
  color: var(--accent-deep);
  text-align: right;
  font-size: 23rpx;
  font-weight: 700;
}

.minimal-task.is-disabled {
  opacity: 0.48;
}
