<view class="page-shell home-page">
  <view class="home-titlebar">
    <view class="home-brand type-brand">{{child.nickname || '佑佑'}}的英语小耳朵</view>
    <view class="home-subtitle type-caption">今日 · Day {{planDayIndex}}</view>
  </view>

  <view class="section-panel" wx:if="{{homeLoading}}">
    <view class="section-title">今日任务加载中</view>
    <view class="section-copy">正在同步学习内容。</view>
  </view>

  <view class="section-panel" wx:elif="{{syncMode === 'cloud-error'}}">
    <view class="section-title">服务暂时不可用</view>
    <view class="section-copy">{{(syncDebug && (syncDebug.publicReason || syncDebug.reason)) || '学习数据暂时没有同步成功，请稍后再试。'}}</view>
  </view>

  <view class="mode-notice" wx:if="{{modeChangedNoticeVisible}}">
    这台手机已切回家长模式
  </view>

  <view class="mode-reminder" wx:if="{{identityConfirmVisible}}">
    <view class="mode-reminder-actions">
      <button class="mode-reminder-action" data-role="parent" bindtap="confirmStudyIdentity">我是家长</button>
      <button class="mode-reminder-action is-primary" data-role="student" bindtap="confirmStudyIdentity">我是学生</button>
    </view>
  </view>

  <swiper class="program-swiper" wx:if="{{hasGroupedTasks}}" previous-margin="32rpx" next-margin="32rpx" circular="{{false}}" indicator-dots="{{true}}" indicator-color="rgba(37, 35, 33, 0.14)" indicator-active-color="#252321">
    <block wx:for="{{groupedDailyTasks}}" wx:key="category">
      <swiper-item>
        <view class="program-slide card {{item.nextTask.isPendingAsset ? 'is-disabled' : ''}}" bindtap="openTask" data-category="{{item.nextTask.category}}" data-task-id="{{item.nextTask.taskId}}" data-disabled="{{item.nextTask.isPendingAsset}}">
          <view class="slide-top">
            <view class="slide-name">{{item.categoryLabel}}</view>
            <view class="slide-state {{item.completedCount === item.totalCount ? 'is-done' : item.nextTask.isPendingAsset ? 'is-waiting' : ''}}">{{item.programStateText}}</view>
          </view>
          <view class="slide-title">{{item.programSubtitle}}</view>
          <view class="slide-meta type-caption">{{item.textType}}</view>
          <view class="slide-line"></view>

          <block wx:if="{{item.tasks.length > 1}}">
            <block wx:for="{{item.tasks}}" wx:key="taskId" wx:for-item="task">
            <view class="slide-task {{task.isPendingAsset ? 'is-disabled' : ''}}" wx:if="{{task.taskId !== item.nextTask.taskId}}" catchtap="openTask" data-category="{{task.category}}" data-task-id="{{task.taskId}}" data-disabled="{{task.isPendingAsset}}">
              <view>
                <view class="slide-task-title">{{task.displayTitle || task.title}}</view>
                <view class="slide-task-meta type-caption">{{task.progressText}}</view>
              </view>
              <view class="slide-task-state">{{task.completedToday ? '完成' : task.isPendingAsset ? '等待' : '›'}}</view>
            </view>
            </block>
          </block>
        </view>
      </swiper-item>
    </block>
  </swiper>

  <view class="empty-state" wx:if="{{!homeLoading && !hasGroupedTasks && syncMode !== 'cloud-error'}}">今日任务还在准备中。</view>
</view>
