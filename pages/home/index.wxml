<view class="page-shell home-page">
  <view class="home-titlebar">
    <view class="home-brand">{{child.nickname || '佑佑'}}的英语小耳朵</view>
    <view class="home-subtitle">今日打卡 · Day {{planDayIndex}} · {{phaseCopy}}</view>
  </view>

  <view class="primary-checkin card" wx:if="{{primaryTask}}">
    <view class="primary-label">下一条</view>
    <view class="primary-title">{{primaryTask.displayTitle || primaryTask.title}}</view>
    <view class="primary-meta">{{primaryTask.progressText}} · {{primaryTask.textType}}</view>
    <view class="progress-rail primary-progress">
      <view class="progress-rail-fill" style="width: {{primaryProgressPercent}}%;"></view>
    </view>
    <button class="button-primary primary-button" bindtap="openTask" data-category="{{primaryTask.category}}" data-task-id="{{primaryTask.taskId}}" disabled="{{primaryTask.isPendingAsset}}">
      {{primaryTask.completedToday ? '查看' : '开始'}}
    </button>
  </view>

  <view class="section-panel" wx:if="{{syncMode === 'cloud-error'}}">
    <view class="section-title">服务暂时不可用</view>
    <view class="section-copy">{{(syncDebug && (syncDebug.publicReason || syncDebug.reason)) || '学习数据暂时没有同步成功，请稍后再试。'}}</view>
  </view>

  <block wx:for="{{groupedDailyTasks}}" wx:key="category">
    <view class="minimal-program card {{item.nextTask.isPendingAsset ? 'is-disabled' : ''}}" bindtap="openTask" data-category="{{item.nextTask.category}}" data-task-id="{{item.nextTask.taskId}}" data-disabled="{{item.nextTask.isPendingAsset}}">
      <view class="row-between">
        <view>
          <view class="program-name">{{item.categoryLabel}}</view>
          <view class="program-line">{{item.completedCount}}/{{item.totalCount}} · {{item.textType}}</view>
        </view>
        <view class="program-state {{item.completedCount === item.totalCount ? 'is-done' : ''}}">{{item.completedCount === item.totalCount ? '完成' : '›'}}</view>
      </view>

      <block wx:if="{{item.tasks.length > 1}}">
        <block wx:for="{{item.tasks}}" wx:key="taskId" wx:for-item="task">
        <view class="minimal-task {{task.isPendingAsset ? 'is-disabled' : ''}}" catchtap="openTask" data-category="{{task.category}}" data-task-id="{{task.taskId}}" data-disabled="{{task.isPendingAsset}}">
          <view>
            <view class="minimal-task-title">{{task.displayTitle || task.title}}</view>
            <view class="minimal-task-meta">第{{task.planSlotIndex || 1}}条 · {{task.progressText}} · {{task.textType}}</view>
          </view>
          <view class="minimal-task-action">{{task.completedToday ? '完成' : task.isPendingAsset ? '等待' : '›'}}</view>
        </view>
        </block>
      </block>
    </view>
  </block>

  <view class="empty-state" wx:if="{{!hasGroupedTasks && syncMode !== 'cloud-error'}}">今日任务还在准备中。</view>
</view>
