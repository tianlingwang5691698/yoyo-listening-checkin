<view class="page-shell home-page">
  <view class="hero card">
    <view class="eyebrow">DAILY LISTENING</view>
    <view class="hero-title">{{child.nickname || '佑佑'}}的英语小耳朵</view>
    <view class="hero-copy">{{child.welcomeLine}}</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
      <block wx:if="{{syncDebug.resourceLines && syncDebug.resourceLines.length}}">
        <block wx:for="{{syncDebug.resourceLines}}" wx:key="*this">
          <view class="sync-debug-line">{{item}}</view>
        </block>
      </block>
    </view>

    <view class="plan-strip">
      <view>
        <view class="plan-day">Day {{planDayIndex}}</view>
        <view class="plan-name">{{planPhaseLabel}} · {{phaseCopy}}</view>
      </view>
      <view class="plan-progress">{{completedTaskCountToday}} / {{activeTaskCount || planTaskCount || 3}}</view>
    </view>

    <view class="hero-stats">
      <view class="hero-stat">
        <text class="hero-stat-value">{{stats.streakDays}}</text>
        <text class="hero-stat-label">连续天数</text>
      </view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{stats.completedDays}}</text>
        <text class="hero-stat-label">完成打卡</text>
      </view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{stats.totalMinutes}}</text>
        <text class="hero-stat-label">累计分钟</text>
      </view>
    </view>
  </view>

  <view class="assignment card">
    <view class="row-between">
      <view>
        <view class="section-title">今日任务计划</view>
        <view class="section-copy">
          {{allDailyDone ? '今天的学习计划已经全部完成。' : '按计划轮次完成每一条，每条听满 3 遍。'}}
        </view>
      </view>
      <view class="pill">{{phaseCopy}}</view>
    </view>
  </view>

  <view class="assignment card" wx:if="{{syncMode === 'cloud-error'}}">
    <view class="row-between">
      <view>
        <view class="section-title">服务暂时不可用</view>
        <view class="section-copy">学习数据暂时没有同步成功，请稍后再试。</view>
      </view>
      <view class="pill">云端</view>
    </view>
    <view class="flow-card">
      <view class="flow-title">当前错误</view>
      <view class="flow-copy">{{(syncDebug && (syncDebug.publicReason || syncDebug.reason)) || '云端服务暂时不可用，请稍后再试。'}}</view>
    </view>
  </view>

  <block wx:for="{{groupedDailyTasks}}" wx:key="category">
    <view class="task-group card group-{{item.category}}">
      <view class="row-between group-head">
        <view>
          <view class="section-title">{{item.categoryLabel}}</view>
          <view class="section-copy">已完成 {{item.completedCount}} / {{item.totalCount}}</view>
        </view>
        <view class="status-badge {{item.completedCount === item.totalCount ? '' : 'is-warn'}}">{{item.completedCount === item.totalCount ? '已完成' : '进行中'}}</view>
      </view>

      <block wx:for="{{item.tasks}}" wx:key="taskId" wx:for-item="task">
        <view class="task-card card-subtle">
          <view class="task-main">
            <view class="task-title">{{task.displayTitle || task.title}}</view>
            <view class="task-meta">
              <text>第{{task.planSlotIndex || 1}}条</text>
              <text>{{task.progressText}}</text>
              <text>{{task.textType}}</text>
            </view>
            <view class="task-note">{{task.audioCompactTitle || task.displaySubtitle || task.note}}</view>
          </view>
          <button class="task-button {{task.completedToday ? 'is-done' : ''}}" bindtap="openTask" data-category="{{task.category}}" data-task-id="{{task.taskId}}" disabled="{{task.isPendingAsset}}">
            {{task.actionText}}
          </button>
        </view>
      </block>
    </view>
  </block>

  <view class="empty-state" wx:if="{{!hasGroupedTasks && syncMode !== 'cloud-error'}}">
    今日任务还在准备中。
  </view>
</view>
