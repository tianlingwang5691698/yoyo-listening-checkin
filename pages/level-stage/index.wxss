.stage-hero {
  margin-top: 56rpx;
  padding: 34rpx 30rpx;
  background: rgba(255, 255, 255, 0.84);
}

.stage-title {
  margin-top: 12rpx;
}

.stage-hint {
  margin-top: 12rpx;
}

.stage-total {
  margin-top: 18rpx;
  padding: 28rpx 30rpx;
  background: rgba(255, 255, 255, 0.84);
}

.total-label {
  color: var(--text-muted);
}

.total-value {
  margin-top: 10rpx;
  color: var(--text-strong);
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
}

.task-group-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.84);
}

.task-group-row.is-disabled {
  opacity: 0.48;
}

.group-name {
  color: var(--text-strong);
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.group-meta {
  margin-top: 10rpx;
}

.group-side {
  flex-shrink: 0;
  text-align: right;
}

.group-minutes {
  color: var(--text-muted);
}

.group-state {
  margin-top: 8rpx;
  color: var(--accent-deep);
  font-size: 28rpx;
  font-weight: 700;
}

.empty-combo {
  margin-top: 18rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.84);
}

.empty-title {
  color: var(--text-strong);
  font-size: 30rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 10rpx;
}
