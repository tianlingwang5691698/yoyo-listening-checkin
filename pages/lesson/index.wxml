<view class="page-shell lesson-page" wx:if="{{task}}">
  <view class="lesson-hero product-hero tone-{{task.coverTone}} cover-variant-{{task.coverVariant}}">
    <view class="lesson-hero-top">
      <view class="pill">{{task.coverBadge || task.categoryLabel}}</view>
      <view class="status-badge {{studyWriteAllowed ? (task.completedToday ? '' : 'is-warn') : 'is-muted'}}">{{studyWriteAllowed ? (task.completedToday ? '完成' : '训练中') : '试听'}}</view>
    </view>
    <view class="lesson-title type-page-title">{{(currentAudio && currentAudio.title) || task.displayTitle || task.title}}</view>
    <view class="lesson-mode" wx:if="{{!studyWriteAllowed}}">家长模式 · 不计入打卡</view>
    <view class="lesson-copy" wx:if="{{task.displaySubtitle}}">{{task.displaySubtitle}}</view>
    <view class="lesson-copy" wx:elif="{{task.coverMeta}}">{{task.coverMeta}}</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
      <block wx:if="{{syncDebug.resourceLines && syncDebug.resourceLines.length}}">
        <block wx:for="{{syncDebug.resourceLines}}" wx:key="*this">
          <view class="sync-debug-line">{{item}}</view>
        </block>
      </block>
    </view>
  </view>

  <view class="section-panel player-card">
    <view class="pass-steps">
      <view class="pass-step {{progress.playCount >= 1 ? 'is-done' : 'is-current'}}">1</view>
      <view class="pass-step {{progress.playCount >= 2 ? 'is-done' : progress.playCount >= 1 ? 'is-current' : ''}}">2</view>
      <view class="pass-step {{progress.playCount >= 3 ? 'is-done' : progress.playCount >= 2 ? 'is-current' : ''}}">3</view>
    </view>
    <view class="row-between player-header">
      <view wx:if="{{!task.isPendingAsset}}">
        <view class="section-copy error-copy" wx:if="{{audioError}}">{{audioError}}</view>
        <view class="section-copy" wx:if="{{showCloudDebug && currentAudio && currentAudio.cloudPath}}">云路径：{{currentAudio.cloudPath}}</view>
        <view class="section-copy" wx:if="{{showCloudDebug && currentAudio && currentAudio.fileID}}">fileId：{{currentAudio.fileID}}</view>
        <view class="section-copy" wx:if="{{showCloudDebug && currentAudio && currentAudio.src}}">src：{{currentAudio.src}}</view>
        <view class="section-copy error-copy" wx:if="{{showCloudDebug && audioErrorDetail}}">错误详情：{{audioErrorDetail}}</view>
      </view>
    </view>
    <view class="custom-player" wx:if="{{!task.isPendingAsset}}">
      <view class="player-panel quest-{{task.category}}">
        <view class="player-info-block">
          <view class="player-info-top">
            <view>
              <view class="media-title" wx:if="{{currentAudio && currentAudio.title}}">{{currentAudio.title}}</view>
              <view class="player-status">{{isPlaying ? '正在播放' : (audioResolving ? '正在准备' : (audioReady ? '已暂停' : '等待播放'))}}</view>
            </view>
          </view>
        </view>
        <view class="player-main">
          <view class="player-toggle {{audioResolving ? 'is-loading' : ''}}" bindtap="toggleAudio">
            <view class="player-toggle-icon {{isPlaying ? 'is-pause' : 'is-play'}}"></view>
          </view>
        </view>
        <view class="player-progress">
          <view class="player-progress-meta">
            <view class="player-progress-label">{{isPlaying ? '播放中' : audioResolving ? '准备中' : audioReady ? '已暂停' : '等待播放'}}</view>
            <view class="player-time">{{currentTimeLabel}} / {{durationLabel}}</view>
          </view>
          <view class="progress-rail player-progress-track">
            <view class="progress-rail-fill player-progress-fill quest-fill-{{task.category}}" style="width: {{progressPercent}}%;"></view>
          </view>
        </view>
        <view class="player-actions action-row">
          <button class="player-action player-action-rewind {{canRewind ? '' : 'is-disabled'}}" bindtap="rewindAudio">5 秒</button>
          <button class="player-action player-rate-toggle" bindtap="togglePlaybackRate">×{{playbackRateText}}</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section-panel transcript-card" wx:if="{{progress && progress.transcriptVisible}}">
    <view class="row-between transcript-header">
      <view>
        <view class="section-title type-section-title">文本</view>
      </view>
      <view class="pill transcript-pill" wx:if="{{!transcriptLines.length}}">{{task.transcriptStatus === 'pending' ? '准备中' : '暂无文本'}}</view>
    </view>

    <view class="transcript-focus" wx:if="{{transcriptLines.length}}">
      <view
        class="transcript-focus-line is-prev {{prevLine ? 'is-ready' : 'is-empty'}}"
        wx:if="{{prevLine}}"
        data-index="{{activeLineIndex - 1}}"
        bindtap="seekToLine"
      >
        <view class="transcript-focus-text">{{prevLine.text}}</view>
      </view>
      <view class="transcript-focus-line is-prev is-empty" wx:else>
        <view class="transcript-focus-text"> </view>
      </view>

      <view
        class="transcript-focus-line is-active"
        wx:if="{{activeLine}}"
        data-index="{{activeLineIndex}}"
        bindtap="seekToLine"
      >
        <view class="transcript-focus-text" wx:if="{{transcriptSyncGranularity === 'word' && activeLine.words && activeLine.words.length}}">
          <block wx:for="{{activeLine.words}}" wx:key="wordId">
            <text class="transcript-word {{index === activeWordIndex ? 'is-active' : ''}}">{{item.text}} </text>
          </block>
        </view>
        <view class="transcript-focus-text" wx:else>{{activeLine.text}}</view>
      </view>
      <view class="transcript-focus-line is-active is-empty" wx:else>
        <view class="transcript-focus-text">音频开始后，这一句会在这里突出显示。</view>
      </view>

      <view
        class="transcript-focus-line is-next {{nextLine ? 'is-ready is-disabled' : 'is-empty'}}"
        wx:if="{{nextLine}}"
        data-index="{{activeLineIndex + 1}}"
        bindtap="seekToLine"
      >
        <view class="transcript-focus-text">{{nextLine.text}}</view>
      </view>
      <view class="transcript-focus-line is-next is-empty" wx:else>
        <view class="transcript-focus-text"> </view>
      </view>
    </view>

    <view class="transcript-empty" wx:elif="{{task.transcriptStatus === 'pending'}}">
      <view class="transcript-empty-title">文本准备中</view>
    </view>

    <view class="transcript-empty" wx:else>
      <view class="transcript-empty-title">暂无文本</view>
    </view>
  </view>

  <view class="section-panel transcript-card" wx:else>
    <view class="transcript-empty">
      <view class="transcript-empty-title">这一遍先盲听</view>
    </view>
  </view>

</view>

<view class="page-shell lesson-page" wx:elif="{{syncMode === 'cloud-error'}}">
  <view class="lesson-hero tone-peach cover-variant-unlock">
    <view class="lesson-hero-top">
      <view class="pill">云端</view>
    </view>
    <view class="lesson-title">课程暂时不可用</view>
    <view class="lesson-copy">学习内容暂时没有同步成功，请稍后再试。</view>
    <view class="sync-debug is-local" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
      <block wx:if="{{syncDebug.resourceLines && syncDebug.resourceLines.length}}">
        <block wx:for="{{syncDebug.resourceLines}}" wx:key="*this">
          <view class="sync-debug-line">{{item}}</view>
        </block>
      </block>
    </view>
  </view>

  <view class="card result-card">
    <view class="result-badge">服务异常</view>
    <view class="result-title">请稍后再重试</view>
    <view class="result-copy">{{(syncDebug && (syncDebug.publicReason || syncDebug.reason)) || '云端服务暂时不可用，请稍后再试。'}}</view>
  </view>
</view>
