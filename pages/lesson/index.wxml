<view class="page-shell lesson-page" wx:if="{{task}}">
  <view class="lesson-hero tone-{{task.coverTone}} cover-variant-{{task.coverVariant}}">
    <view class="lesson-hero-top">
      <view class="pill">{{task.coverBadge || task.categoryLabel}}</view>
    </view>
    <view class="lesson-title">{{task.displayTitle || task.title}}</view>
    <view class="lesson-copy" wx:if="{{task.displaySubtitle}}">{{task.displaySubtitle}}</view>
    <view class="lesson-copy" wx:elif="{{task.coverMeta}}">{{task.coverMeta}}</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
      <block wx:if="{{syncDebug.resourceLines && syncDebug.resourceLines.length}}">
        <block wx:for="{{syncDebug.resourceLines}}" wx:key="*this">
          <view class="sync-debug-line">{{item}}</view>
        </block>
      </block>
    </view>
    <view class="hero-meta">
      <text>每天 3 遍</text>
      <text>{{task.isPendingAsset ? '等待音频' : '纯音频任务'}}</text>
      <text>{{task.completedToday ? '今天已完成' : '今天进行中'}}</text>
    </view>
  </view>

  <view class="card progress-card">
    <view class="section-title">今天的三遍节奏</view>
    <view class="section-copy">{{progress.currentPass < progress.repeatTarget ? (task.transcriptTrackId ? '这三遍都可以边听边看文本，先把这一遍稳稳听完。' : '这三遍先按纯听力推进，后面再补文本高亮。') : (task.transcriptTrackId ? '最后一遍也可以顺着文本完整过一遍。' : '最后一遍先按纯听力完成。')}}</view>
    <view class="step-row">
      <view class="step-pill {{progress.playCount >= 1 ? 'is-done' : 'is-current'}}">1. 第 1 遍{{task.transcriptTrackId ? ' + 文本' : ''}}</view>
      <view class="step-pill {{progress.playCount >= 2 ? 'is-done' : progress.playCount >= 1 ? 'is-current' : ''}}">2. 第 2 遍{{task.transcriptTrackId ? ' + 文本' : ''}}</view>
      <view class="step-pill {{progress.playCount >= 2 ? 'is-current' : ''}}">3. 第 3 遍{{task.transcriptTrackId ? ' + 文本' : ''}}</view>
    </view>
  </view>

  <view class="card player-card">
    <view class="row-between player-header">
      <view>
        <view class="section-title">今天这条音频</view>
        <view wx:if="{{!task.isPendingAsset}}">
          <view class="section-copy">
            现在是第 {{progress.currentPass}} 遍，共 {{progress.repeatTarget}} 遍。
          </view>
          <view class="section-copy" wx:if="{{audioSource}}">
            音频来源：{{audioSource}}
          </view>
          <view class="section-copy" wx:if="{{audioPlaybackMode && audioPlaybackMode !== 'idle'}}">
            播放链路：{{audioPlaybackMode}}
          </view>
          <view class="section-copy" wx:if="{{showCloudDebug && task.audioCloudPath}}">
            云路径：{{task.audioCloudPath}}
          </view>
          <view class="section-copy" wx:if="{{showCloudDebug && task.audioFileId}}">
            fileId：{{task.audioFileId}}
          </view>
          <view class="section-copy" wx:if="{{audioResolving}}">
            播放状态：正在解析云端音频
          </view>
          <view class="section-copy" wx:elif="{{audioReady}}">
            播放状态：已就绪
          </view>
          <view class="section-copy error-copy" wx:if="{{audioError}}">
            播放状态：{{audioError}}
          </view>
          <view class="section-copy error-copy" wx:if="{{showCloudDebug && audioErrorDetail}}">
            错误详情：{{audioErrorDetail}}
          </view>
        </view>
        <view wx:else>
          <view class="section-copy">
            这个分类暂时还没有音频，等你把素材放进来后就会开始轮换。
          </view>
        </view>
      </view>
      <view class="player-stage" wx:if="{{!task.isPendingAsset}}">{{progress.currentPass}} / {{progress.repeatTarget}}</view>
    </view>
    <view class="custom-player" wx:if="{{!task.isPendingAsset}}">
      <view class="player-panel quest-{{task.category}}">
        <view class="player-info-block">
          <view class="player-info-top">
            <view>
              <view class="media-title" wx:if="{{task.audioCompactTitle}}">{{task.audioCompactTitle}}</view>
              <view class="player-status">{{isPlaying ? '正在播放' : (audioResolving ? '正在准备' : (audioReady ? '已暂停' : '等待播放'))}}</view>
            </view>
            <view class="player-speed-badge">当前 {{playbackRate.toFixed(1)}}x</view>
          </view>
        </view>
        <view class="player-main">
          <button class="player-toggle" bindtap="toggleAudio" loading="{{audioResolving}}" disabled="{{task.isPendingAsset}}">
            <text>{{isPlaying ? '||' : '>'}}</text>
          </button>
          <view class="player-copy">
            <view class="player-main-label">播放 / 暂停</view>
            <view class="player-main-copy">按三遍训练节奏稳稳往前听，不提供快进。</view>
          </view>
        </view>
        <view class="player-progress">
          <view class="player-progress-meta">
            <view class="player-progress-label">播放进度</view>
            <view class="player-time">{{currentTimeLabel}} / {{durationLabel}}</view>
          </view>
          <view class="player-progress-track">
            <view class="player-progress-fill quest-fill-{{task.category}}" style="width: {{progressPercent}}%;"></view>
          </view>
        </view>
        <view class="player-actions">
          <button class="player-action player-action-rewind {{canRewind ? '' : 'is-disabled'}}" bindtap="rewindAudio">后退 5 秒</button>
          <view class="player-rate-group">
            <block wx:for="{{playbackRateOptions}}" wx:key="*this">
              <button
                class="player-action player-rate-option {{playbackRate === item ? 'is-active-rate' : ''}}"
                bindtap="setPlaybackRate"
                data-rate="{{item}}"
              >{{item.toFixed(1)}}x</button>
            </block>
          </view>
        </view>
      </view>
    </view>
    <view class="listen-state {{task.completedToday ? 'is-ready' : 'is-waiting'}}">
      已完成 {{progress.playStepText}}
    </view>
  </view>

  <view class="card quest-card quest-{{task.category}}">
    <view class="row-between quest-top">
      <view>
        <view class="section-title">这一项的奖励线</view>
        <view class="section-copy">完成 3 遍，就像过完今天这一关。</view>
      </view>
      <view class="pill">{{task.rewardBadge}}</view>
    </view>
    <view class="quest-title">{{task.rewardTitle}}</view>
    <view class="quest-copy">{{task.rewardCopy}}</view>
    <view class="quest-track">
      <view class="quest-node {{progress.playCount >= 1 ? 'is-on' : ''}}"></view>
      <view class="quest-line {{progress.playCount >= 1 ? 'is-on' : ''}}"></view>
      <view class="quest-node {{progress.playCount >= 2 ? 'is-on' : ''}}"></view>
      <view class="quest-line {{progress.textUnlocked ? 'is-on' : ''}}"></view>
      <view class="quest-node {{task.completedToday ? 'is-on is-final' : progress.textUnlocked ? 'is-current is-final' : 'is-final'}}"></view>
    </view>
    <view class="quest-labels">
      <view>盲听 1</view>
      <view>盲听 2</view>
      <view>文本通关</view>
    </view>
  </view>

  <view class="card source-card" wx:if="{{scriptSource}}">
    <view class="section-title">文本来源</view>
    <view class="section-copy">有文本的条目会从这里同步显示出来。</view>
    <view class="source-name">{{scriptSource.title}}</view>
  </view>

  <view class="card transcript-card">
    <view class="row-between transcript-header">
      <view>
        <view class="section-title">同步文本</view>
        <view class="section-copy">
          {{transcriptLines.length ? '现在可以边听边看文本。' : task.transcriptStatus === 'pending' ? '这条的逐句高亮正在准备中，先按纯听力完成也可以。' : '这条音频目前没有可用文本，也可以照常完成。'}}
        </view>
      </view>
      <view class="pill transcript-pill">{{transcriptLines.length ? 'TEXT ON' : task.transcriptStatus === 'pending' ? 'TEXT SOON' : 'NO TEXT'}}</view>
    </view>

    <view class="transcript-focus" wx:if="{{transcriptLines.length}}">
      <view
        class="transcript-focus-line is-prev {{prevLine ? 'is-ready' : 'is-empty'}}"
        wx:if="{{prevLine}}"
        data-index="{{activeLineIndex - 1}}"
        bindtap="seekToLine"
      >
        <view class="transcript-focus-text">{{prevLine.text}}</view>
      </view>
      <view class="transcript-focus-line is-prev is-empty" wx:else>
        <view class="transcript-focus-text"> </view>
      </view>

      <view
        class="transcript-focus-line is-active"
        wx:if="{{activeLine}}"
        data-index="{{activeLineIndex}}"
        bindtap="seekToLine"
      >
        <view class="transcript-focus-text">{{activeLine.text}}</view>
      </view>
      <view class="transcript-focus-line is-active is-empty" wx:else>
        <view class="transcript-focus-text">音频开始后，这一句会在这里突出显示。</view>
      </view>

      <view
        class="transcript-focus-line is-next {{nextLine ? 'is-ready' : 'is-empty'}}"
        wx:if="{{nextLine}}"
        data-index="{{activeLineIndex + 1}}"
        bindtap="seekToLine"
      >
        <view class="transcript-focus-text">{{nextLine.text}}</view>
      </view>
      <view class="transcript-focus-line is-next is-empty" wx:else>
        <view class="transcript-focus-text"> </view>
      </view>
    </view>

    <view class="transcript-empty" wx:elif="{{task.transcriptStatus === 'pending'}}">
      <view class="transcript-empty-title">这条文本准备中</view>
      <view class="transcript-empty-copy">前 6 条已经接入高亮，这一条会在后续批次补上。今天先按纯听力完成，不会卡住任务。</view>
    </view>

    <view class="transcript-empty" wx:else>
      <view class="transcript-empty-title">这一条没有文本</view>
      <view class="transcript-empty-copy">没有文本也不会影响今天完成 3 遍任务。</view>
    </view>
  </view>

  <view class="card result-card" wx:if="{{task.completedToday}}">
    <view class="result-badge">TODAY DONE</view>
    <view class="result-title">{{task.categoryLabel}} 今天完成了</view>
    <view class="result-copy">这项任务已经听满 3 遍，明天会自动轮到下一条。</view>
  </view>

  <view class="card result-card" wx:if="{{todayRecord}}">
    <view class="result-badge">DAILY CHECKIN</view>
    <view class="result-title">今天的总打卡已经点亮</view>
    <view class="result-copy">连续 {{todayRecord.streakSnapshot}} 天坚持，今天完成的分类已经记下来了。</view>
  </view>

  <view class="card history-card">
    <view class="section-title">这个分类的历史</view>
    <view class="section-copy">完成 3 遍以后，这里会留下该分类的完成记录。</view>
    <block wx:if="{{history.length}}">
      <block wx:for="{{history}}" wx:key="date">
        <view class="history-row">
          <view>
            <view class="history-date">{{item.date}}</view>
            <view class="history-time">{{item.taskTitle}}</view>
          </view>
          <view class="history-streak">{{item.playCount}} / 3</view>
        </view>
      </block>
    </block>
    <view class="section-copy" wx:else>还没有这个分类的完成记录。</view>
  </view>
</view>
