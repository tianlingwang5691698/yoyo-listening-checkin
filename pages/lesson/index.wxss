.lesson-hero {
  position: relative;
  overflow: hidden;
  padding-bottom: 34rpx;
  box-shadow: var(--shadow-card);
}

.cover-variant-peppa,
.cover-variant-unlock,
.cover-variant-song,
.tone-peach {
  background: #fffdfa;
}

.lesson-hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.lesson-title {
  position: relative;
  z-index: 1;
}

.lesson-copy {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  color: rgba(47, 36, 31, 0.72);
  font-size: 26rpx;
}

.sync-debug {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
  font-size: 22rpx;
  line-height: 1.5;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.sync-debug-line {
  margin-top: 8rpx;
  word-break: break-all;
}

.player-card,
.transcript-card {
  margin-top: 24rpx;
}

.pass-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.pass-step {
  min-width: 0;
  min-height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-soft);
  background: rgba(255, 255, 255, 0.66);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 700;
}

.pass-step.is-current {
  background: var(--accent-soft);
  border-color: rgba(239, 124, 85, 0.26);
}

.pass-step.is-done {
  background: var(--growth-soft);
  border-color: rgba(102, 185, 133, 0.3);
}

.error-copy {
  color: #d14d2f;
}

.player-header {
  align-items: flex-start;
  min-height: 0;
}

.custom-player {
  margin-top: 0;
}

.player-panel {
  padding: 24rpx;
  border-radius: 30rpx;
  background: transparent;
}

.player-info-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.media-title {
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 700;
}

.player-status {
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.player-main {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 12rpx 0 4rpx;
}

.player-toggle {
  width: 132rpx;
  min-width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent);
  color: #fffaf6;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 14rpx 28rpx rgba(239, 124, 85, 0.2);
}

.player-toggle.is-loading {
  opacity: 0.72;
}

.player-toggle-icon {
  display: block;
  line-height: 1;
  transform: translateX(4rpx);
}

.player-toggle-icon.is-pause {
  transform: none;
}

.player-progress {
  margin-top: 24rpx;
  padding-top: 6rpx;
}

.player-progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.player-progress-label,
.player-time {
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 600;
}

.player-time {
  flex-shrink: 0;
}

.player-progress-track {
  background: rgba(84, 57, 45, 0.1);
}

.player-progress-fill {
  background: var(--accent);
}

.player-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
}

.player-action {
  flex: 1;
  min-width: 0;
  padding: 20rpx 18rpx;
  border: none;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: var(--text-main);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.player-action::after {
  border: none;
}

.player-rate-toggle {
  background: var(--accent);
  color: #fffaf6;
}

.player-action.is-disabled {
  opacity: 0.45;
}

.transcript-header {
  align-items: flex-start;
}

.transcript-pill {
  flex-shrink: 0;
}

.transcript-focus {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: #fbf8f2;
}

.transcript-focus-line {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 118rpx;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  text-align: center;
}

.transcript-focus-line + .transcript-focus-line {
  margin-top: 14rpx;
}

.transcript-focus-line.is-prev,
.transcript-focus-line.is-next {
  background: rgba(255, 248, 242, 0.88);
}

.transcript-focus-line.is-active {
  min-height: 156rpx;
  background: #fffdfa;
}

.transcript-focus-line.is-empty {
  opacity: 0.35;
}

.transcript-focus-line.is-disabled {
  opacity: 0.72;
}

.transcript-focus-text {
  color: #7f6a5c;
  font-size: 26rpx;
  line-height: 1.7;
}

.transcript-focus-line.is-prev .transcript-focus-text,
.transcript-focus-line.is-next .transcript-focus-text {
  color: rgba(79, 57, 45, 0.52);
}

.transcript-focus-line.is-next.is-disabled .transcript-focus-text {
  color: rgba(79, 57, 45, 0.38);
}

.transcript-focus-line.is-active .transcript-focus-text {
  color: var(--text-main);
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.55;
}

.transcript-word {
  display: inline;
  padding: 2rpx 4rpx;
  border-radius: 10rpx;
}

.transcript-word.is-active {
  background: rgba(239, 124, 85, 0.18);
  color: #e7683c;
}

.transcript-empty {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fff8f2;
}

.transcript-empty-title {
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 700;
}
