<view class="page-shell identity-page">
  <view class="identity-hero product-hero">
    <view class="product-title type-page-title">绑定身份</view>
    <view class="product-copy">用孩子 ID，把家长和同一份打卡记录连起来。</view>
  </view>

  <view class="role-switch section-panel">
    <view class="role-option {{role === 'parent' ? 'is-active' : ''}}" data-role="parent" bindtap="chooseRole">
      <view class="role-title">我是家长</view>
      <view class="role-copy">输入孩子 6 位 ID。</view>
    </view>
    <view class="role-option {{role === 'student' ? 'is-active' : ''}}" data-role="student" bindtap="chooseRole">
      <view class="role-title">我是学生</view>
      <view class="role-copy">查看自己的孩子 ID。</view>
    </view>
  </view>

  <view class="bind-card form-panel" wx:if="{{role === 'parent'}}">
    <view class="section-title">孩子 ID</view>
    <view class="section-copy">绑定后可查看日报和成长记录。</view>
    <input class="form-input identity-input code-input" type="number" maxlength="6" placeholder="输入 6 位数字" value="{{childCode}}" bindinput="handleChildCodeInput" />
    <input class="form-input identity-input" placeholder="你的称呼，例如 妈妈 / 爸爸" value="{{displayName}}" bindinput="handleDisplayNameInput" />
    <button class="button-primary" bindtap="submitIdentity">绑定孩子记录</button>
  </view>

  <view class="bind-card form-panel" wx:else>
    <view class="section-title">我的孩子 ID</view>
    <view class="section-copy">把这个数字给家长，家长即可加入记录。</view>
    <view class="student-code">{{child.childLoginCode || '生成中'}}</view>
    <button class="button-secondary" bindtap="copyChildCode">复制孩子 ID</button>
  </view>
</view>
