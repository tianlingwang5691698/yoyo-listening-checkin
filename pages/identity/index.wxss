.identity-hero {
  background: var(--surface);
}

.role-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.role-option {
  min-height: 160rpx;
  padding: 24rpx;
  border: 2rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.68);
}

.role-option.is-active {
  border-color: rgba(37, 35, 33, 0.18);
  background: rgba(37, 35, 33, 0.06);
}

.role-title {
  color: var(--text-main);
  font-size: 30rpx;
  font-weight: 700;
}

.role-copy {
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.55;
}

.identity-input {
  margin-top: 22rpx;
}

.code-input {
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
}

.bind-card .button-primary,
.bind-card .button-secondary {
  margin-top: 22rpx;
}

.student-code {
  margin-top: 24rpx;
  color: var(--text-strong);
  font-size: 68rpx;
  line-height: 1;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}
