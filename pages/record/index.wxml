<view class="page-shell record-page">
  <view class="record-hero card">
    <view class="record-hero-top">
      <view>
        <view class="record-eyebrow">GROWTH</view>
        <view class="record-title">成长正在发生</view>
      </view>
      <view class="status-badge">{{syncMode === 'cloud' ? '已同步' : '本地状态'}}</view>
    </view>
    <view class="section-copy">把每天一小段听力，慢慢变成稳定的英语节奏。</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
    </view>

    <view class="metric-switch">
      <view class="metric-tab {{metricMode === 'streak' ? 'is-active' : ''}}" data-mode="streak" bindtap="switchMetric">连续打卡</view>
      <view class="metric-tab {{metricMode === 'total' ? 'is-active' : ''}}" data-mode="total" bindtap="switchMetric">累计打卡</view>
    </view>

    <view class="metric-board">
      <view>
        <view class="metric-value">{{heroMetricValue}}</view>
        <view class="metric-label">{{heroMetricLabel}}天</view>
      </view>
      <view class="metric-mark">
        <view class="metric-mark-main">{{stats.streakDays > 6 ? '稳' : stats.completedDays > 0 ? '亮' : '启'}}</view>
        <view class="metric-mark-copy">{{lastCheckinText}}</view>
      </view>
    </view>

    <view class="data-grid record-stats">
      <view class="data-cell">
        <text class="data-value">{{stats.streakDays || 0}}</text>
        <text class="data-label">连续天数</text>
      </view>
      <view class="data-cell">
        <text class="data-value">{{stats.completedDays || 0}}</text>
        <text class="data-label">累计打卡</text>
      </view>
      <view class="data-cell">
        <text class="data-value">{{stats.totalMinutes || 0}}</text>
        <text class="data-label">累计分钟</text>
      </view>
    </view>
  </view>

  <view class="calendar-card card">
    <view class="row-between">
      <view>
        <view class="section-title">本月听力热力图</view>
        <view class="section-copy">颜色越深，表示当天完成记录越多。</view>
      </view>
      <view class="pill">{{stats.completedDays || 0}} 天</view>
    </view>
    <view class="week-grid">
      <block wx:for="{{weekLabels}}" wx:key="*this">
        <view class="week-label">{{item}}</view>
      </block>
    </view>
    <view class="calendar-grid">
      <block wx:for="{{monthHeatmap}}" wx:key="key">
        <view class="calendar-cell {{item.isBlank ? 'is-blank' : ''}} {{item.isToday ? 'is-today' : ''}} {{item.isCatchupTarget ? 'is-catchup-target' : ''}}">
          <view wx:if="{{!item.isBlank}}" class="calendar-dot level-{{item.intensity}}">
            {{item.dayText}}
          </view>
        </view>
      </block>
    </view>
    <view class="calendar-legend">
      <view><text class="legend-dot level-0"></text>未完成</view>
      <view><text class="legend-dot level-2"></text>已点亮</view>
      <view><text class="legend-dot is-target"></text>可追赶</view>
    </view>
  </view>

  <view class="catchup card">
    <view class="row-between">
      <view>
        <view class="section-title">追赶任务</view>
        <view class="section-copy" wx:if="{{catchupState.canCatchup}}">
          完成这一批真实任务后，会点亮 {{catchupState.missedDate}}。
        </view>
        <view class="section-copy" wx:else>
          {{catchupState.reason === 'finish-current-plan-first' ? '先完成今天计划，之后才能追赶落下日期。' : catchupState.reason === 'catchup-used-today' ? '今天已经追赶过一批，明天继续。' : '目前没有需要追赶的日期。'}}
        </view>
      </view>
      <view class="status-badge {{catchupState.canCatchup ? '' : 'is-muted'}}">{{catchupState.canCatchup ? '可追赶' : '已安排'}}</view>
    </view>
    <block wx:if="{{catchupState.canCatchup}}">
      <block wx:for="{{catchupTasks}}" wx:key="taskId">
        <view class="catchup-row {{item.completedToday ? 'is-done' : ''}}" data-category="{{item.category}}" data-task-id="{{item.taskId}}" bindtap="openCatchupTask">
          <view>
            <view class="catchup-title">{{item.categoryLabel}} · {{item.displayTitle || item.title}}</view>
            <view class="catchup-copy">{{item.completedToday ? '这条已完成' : '进入课程，听满 3 遍才算追赶成功'}}</view>
          </view>
          <view class="catchup-state">{{item.playStepText}}</view>
        </view>
      </block>
    </block>
  </view>

  <view class="quote-card card">
    <view class="section-title">今日鼓励</view>
    <view class="quote-text">{{quoteText}}</view>
    <view class="quote-badge">{{stats.streakDays > 6 ? '本周之星' : stats.streakDays > 0 ? '继续加油' : '今天开始'}}</view>
  </view>

  <view class="total-card card">
    <view class="section-title">累计数据</view>
    <view class="total-list">
      <view class="total-row">
        <text>累计分钟</text>
        <text class="total-value">{{stats.totalMinutes || 0}} 分钟</text>
      </view>
      <view class="total-row">
        <text>完成任务</text>
        <text class="total-value">{{stats.completedTasks || 0}} 项</text>
      </view>
      <view class="total-row">
        <text>当前计划日</text>
        <text class="total-value">Day {{planDayIndex || 1}}</text>
      </view>
    </view>
  </view>
</view>
