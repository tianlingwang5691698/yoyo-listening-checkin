<view class="page-shell record-page">
  <view class="summary card">
    <view class="section-title">成长正在发生</view>
    <view class="section-copy">把每天一小段听力，慢慢变成稳定的英语节奏。</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
    </view>
    <view class="summary-grid">
      <view class="summary-item">
        <view class="summary-value">{{stats.streakDays}}</view>
        <view class="summary-label">连续打卡</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{stats.completedDays}}</view>
        <view class="summary-label">完成打卡</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{stats.totalMinutes}}</view>
        <view class="summary-label">累计分钟</view>
      </view>
    </view>
    <view class="identity-strip">
      <view>当前身份：{{currentMember.displayName ? currentMember.displayName : '微信用户'}}</view>
      <view>最近一次：{{lastCheckinText}}</view>
    </view>
  </view>

  <view class="heatmap card">
    <view class="section-title">最近 28 天</view>
    <view class="section-copy">颜色越深，表示那天完成的听力记录越多。</view>
    <view class="heatmap-grid">
      <block wx:for="{{heatmap}}" wx:key="date">
        <view class="heatmap-cell">
          <view class="heat {{'level-' + item.intensity}}"></view>
          <view class="heat-date">{{item.shortDate}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="catchup card">
    <view class="section-title">追赶补卡</view>
    <view class="section-copy" wx:if="{{catchupState.canCatchup}}">
      已经完成当前计划，可以追赶一批新任务，完成后会点亮 {{catchupState.missedDate}}。
    </view>
    <view class="section-copy" wx:else>
      {{catchupState.reason === 'finish-current-plan-first' ? '先完成当前计划，完成后如果有落下的日期，就能追赶一批新任务。' : catchupState.reason === 'catchup-used-today' ? '今天已经追赶过一批了，明天再继续。' : '目前没有需要追赶的日期。'}}
    </view>
    <block wx:if="{{catchupState.canCatchup}}">
      <block wx:for="{{catchupTasks}}" wx:key="taskId">
        <view class="catchup-row {{item.completedToday ? 'is-done' : ''}}" data-category="{{item.category}}" data-task-id="{{item.taskId}}" bindtap="openCatchupTask">
          <view>
            <view class="catchup-title">{{item.categoryLabel}} · {{item.displayTitle || item.title}}</view>
            <view class="catchup-copy">{{item.completedToday ? '已完成' : '点击进入，完成 3 遍后才算追赶成功'}}</view>
          </view>
          <view class="catchup-state">{{item.playStepText}}</view>
        </view>
      </block>
    </block>
  </view>

  <view class="sticker card">
    <view class="section-title">今日小奖章</view>
    <view class="section-copy">{{stats.streakDays > 0 ? '已经在坚持了，继续把这份节奏守住。' : '今天把该做的音频听完，就会点亮第一枚小奖章。'}}</view>
    <view class="sticker-badge">{{stats.streakDays > 6 ? '本周之星' : stats.streakDays > 0 ? '继续加油' : '今天开始'}}</view>
  </view>
</view>
