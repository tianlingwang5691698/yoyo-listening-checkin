<view class="page-shell record-page">
  <view class="record-hero product-hero">
    <view class="record-hero-top">
      <view>
        <view class="record-eyebrow">成长</view>
        <view class="record-title type-page-title">学习成果</view>
      </view>
      <view class="status-badge">{{syncMode === 'cloud' ? '已同步' : '本地状态'}}</view>
    </view>

    <view class="metric-switch">
      <view class="metric-tab {{metricMode === 'streak' ? 'is-active' : ''}}" data-mode="streak" bindtap="switchMetric">连续</view>
      <view class="metric-tab {{metricMode === 'total' ? 'is-active' : ''}}" data-mode="total" bindtap="switchMetric">累计</view>
    </view>

    <view class="metric-board">
      <view>
        <view class="metric-value">{{heroMetricValue}}</view>
        <view class="metric-label">{{heroMetricLabel}}天</view>
      </view>
    </view>

    <view class="summary-row">
      <view class="summary-item">
        <view class="summary-value">{{stats.completedDays || 0}}</view>
        <view class="summary-label">累计天数</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{stats.totalMinutes || 0}}</view>
        <view class="summary-label">累计分钟</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{stats.completedTasks || 0}}</view>
        <view class="summary-label">完成任务</view>
      </view>
    </view>
  </view>

  <view class="calendar-card section-panel">
    <view class="calendar-head">
      <view class="type-section-title">本月</view>
      <view class="month-control">
        <view class="month-arrow" data-direction="-1" bindtap="switchMonth">‹</view>
        <picker mode="date" value="{{selectedDate}}" end="{{todayDate}}" bindchange="pickDate">
          <view class="month-title">{{calendarTitle}}</view>
        </picker>
        <view class="month-arrow" data-direction="1" bindtap="switchMonth">›</view>
      </view>
    </view>

    <view class="calendar-body" bindtouchstart="handleCalendarTouchStart" bindtouchend="handleCalendarTouchEnd">
      <view class="week-grid">
        <block wx:for="{{weekLabels}}" wx:key="*this">
          <view class="week-label">{{item}}</view>
        </block>
      </view>

      <view class="calendar-grid">
        <block wx:for="{{monthCells}}" wx:key="key">
          <view
            class="calendar-cell {{item.isBlank ? 'is-blank' : ''}} {{item.completed ? 'is-completed' : ''}} {{item.isToday ? 'is-today' : ''}} {{item.isSelected ? 'is-selected' : ''}} {{item.isCatchupTarget ? 'is-catchup-target' : ''}}"
            data-date="{{item.date}}"
            bindtap="selectDate"
          >
            <view wx:if="{{!item.isBlank}}" class="calendar-dot">{{item.dayText}}</view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="day-card section-panel">
    <view class="row-between">
      <view>
        <view class="type-section-title">{{selectedDateLabel}}</view>
        <view class="section-copy">{{selectedDayReport.completedCategories.length ? '已完成' : '未完成'}}</view>
      </view>
      <view class="pill">{{selectedDayReport.totalMinutes || 0}} 分钟</view>
    </view>

    <block wx:if="{{selectedDayReport.items && selectedDayReport.items.length}}">
      <block wx:for="{{selectedDayReport.items}}" wx:key="taskId">
        <view class="report-row">
          <view>
            <view class="report-title">{{item.categoryLabel}}</view>
            <view class="report-copy">{{item.title}}</view>
          </view>
          <view class="report-state {{item.completedToday ? 'is-done' : ''}}">{{item.completedToday ? '完成' : '未完成'}}</view>
        </view>
      </block>
    </block>
    <view class="empty-state" wx:else>这一天还没有记录。</view>
  </view>

  <view class="catchup section-panel">
    <view class="row-between">
      <view>
        <view class="type-section-title">追赶</view>
        <view class="section-copy">{{catchupState.canCatchup ? ('可点亮 ' + catchupState.missedDate) : catchupStatusLabel}}</view>
      </view>
      <view class="status-badge {{catchupStatusClass}}">{{catchupStatusLabel}}</view>
    </view>
    <block wx:if="{{catchupState.canCatchup}}">
      <block wx:for="{{catchupTasks}}" wx:key="taskId">
        <view class="catchup-row {{item.completedToday ? 'is-done' : ''}}" data-category="{{item.category}}" data-task-id="{{item.taskId}}" bindtap="openCatchupTask">
          <view>
            <view class="catchup-title">{{item.categoryLabel}}</view>
            <view class="catchup-copy">{{item.displayTitle || item.title}}</view>
          </view>
          <view class="catchup-state">{{item.playStepText}}</view>
        </view>
      </block>
    </block>
  </view>
</view>
