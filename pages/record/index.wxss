.summary,
.heatmap,
.sticker {
  padding: 30rpx;
}

.summary {
  background: linear-gradient(135deg, #fff4e8 0%, #fffaf1 100%);
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.summary-item {
  padding: 22rpx 0;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.72);
}

.summary-value {
  font-size: 38rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8c7e72;
}

.heatmap,
.sticker {
  margin-top: 24rpx;
}

.heatmap-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx 12rpx;
  margin-top: 24rpx;
}

.heatmap-cell {
  text-align: center;
}

.heat {
  width: 100%;
  height: 80rpx;
  border-radius: 22rpx;
  background: #f4efea;
}

.level-0 {
  background: #f4efea;
}

.level-1 {
  background: #cfead2;
}

.level-2 {
  background: #9fd7a7;
}

.level-3 {
  background: #74b87c;
}

.heat-date {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #8c7e72;
}

.sticker {
  background: linear-gradient(135deg, #f1ffed 0%, #fffef2 100%);
}

.sticker-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  min-width: 220rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #74b87c;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}
