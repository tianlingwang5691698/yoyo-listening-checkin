.record-hero {
  background: var(--surface);
}

.record-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.record-eyebrow {
  color: var(--text-muted);
  font-size: 20rpx;
  font-weight: 600;
}

.record-title {
  margin-top: 12rpx;
}

.metric-switch {
  display: flex;
  gap: 10rpx;
  margin-top: 28rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.06);
}

.metric-tab {
  flex: 1;
  min-height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 700;
}

.metric-tab.is-active {
  background: var(--text-strong);
  color: #fffdfa;
}

.metric-board {
  margin-top: 28rpx;
}

.metric-value {
  color: var(--text-strong);
  font-size: 104rpx;
  line-height: 0.9;
  font-weight: 900;
}

.metric-label {
  margin-top: 16rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 600;
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 28rpx;
}

.summary-item {
  padding: 20rpx 12rpx;
  border: 1rpx solid rgba(37, 35, 33, 0.08);
  border-radius: 20rpx;
}

.summary-value {
  color: var(--text-strong);
  font-size: 30rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 21rpx;
}

.month-title {
  min-width: 150rpx;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: var(--text-main);
  font-size: 24rpx;
  font-weight: 700;
}

.month-arrow {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  background: rgba(37, 35, 33, 0.06);
  font-size: 32rpx;
}

.month-arrow.is-ghost {
  opacity: 0;
}

.week-grid,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.week-grid {
  margin-top: 26rpx;
}

.week-label {
  text-align: center;
  color: var(--text-soft);
  font-size: 20rpx;
  font-weight: 700;
}

.calendar-grid {
  margin-top: 14rpx;
}

.calendar-swiper {
  height: 628rpx;
  margin: -2rpx -30rpx 0;
  overflow: visible;
}

.calendar-slide {
  min-height: 588rpx;
  margin: 0 10rpx;
  padding: 22rpx 20rpx 26rpx;
  border: 1rpx solid rgba(37, 35, 33, 0.06);
  border-radius: 28rpx;
  background: rgba(255, 253, 250, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(37, 35, 33, 0.05);
}

.calendar-slide.is-disabled {
  opacity: 0.36;
}

.calendar-slide-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.calendar-cell {
  min-width: 0;
  height: 76rpx;
}

.calendar-cell.is-blank {
  opacity: 0;
}

.calendar-dot {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4efea;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 700;
}

.calendar-cell.is-completed .calendar-dot {
  background: #e4f1e8;
  color: #4f8f62;
}

.calendar-cell.is-selected .calendar-dot {
  box-shadow: inset 0 0 0 4rpx rgba(239, 124, 85, 0.42);
}

.calendar-cell.is-today .calendar-dot {
  color: var(--text-strong);
}

.calendar-cell.is-catchup-target .calendar-dot {
  box-shadow: inset 0 0 0 4rpx rgba(239, 124, 85, 0.58);
}

.calendar-swipe-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 10rpx;
  color: var(--text-soft);
  font-size: 20rpx;
  font-weight: 700;
}

.swipe-mark {
  width: 28rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.12);
}

.day-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.day-count {
  color: var(--text-soft);
  font-size: 20rpx;
  font-weight: 700;
}

.report-row,
.catchup-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.report-row:last-child,
.catchup-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.report-title,
.catchup-title {
  color: var(--text-main);
  font-size: 27rpx;
  font-weight: 700;
}

.report-copy,
.catchup-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.report-state,
.catchup-state {
  flex-shrink: 0;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 700;
  text-align: right;
}

.report-state.is-done {
  color: var(--accent-deep);
}

.report-progress {
  margin-top: 6rpx;
  color: var(--text-soft);
  font-size: 19rpx;
}

.catchup-row.is-done {
  opacity: 0.56;
}
