.record-hero {
  background:
    radial-gradient(circle at 82% 12%, rgba(239, 124, 85, 0.14), transparent 28%),
    linear-gradient(135deg, #fff8ee 0%, #fffdf8 100%);
}

.record-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.record-eyebrow {
  font-size: 20rpx;
  color: #ad7f55;
  font-weight: 800;
}

.record-title {
  margin-top: 12rpx;
  font-size: 48rpx;
  line-height: 1.14;
  font-weight: 900;
  color: var(--text-main);
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.metric-switch {
  display: flex;
  gap: 10rpx;
  margin-top: 28rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.metric-tab {
  flex: 1;
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.metric-tab.is-active {
  background: var(--text-main);
  color: #fffaf6;
}

.metric-board {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #edf9ef 0%, #fff8ea 100%);
}

.metric-value {
  font-size: 104rpx;
  line-height: 0.9;
  font-weight: 900;
  color: var(--growth-deep);
}

.metric-label {
  margin-top: 16rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 700;
}

.metric-mark {
  width: 156rpx;
  min-height: 156rpx;
  padding: 18rpx;
  border-radius: 36rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.72);
}

.metric-mark-main {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--accent-deep);
}

.metric-mark-copy {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.record-stats {
  margin-top: 18rpx;
}

.week-grid,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.week-grid {
  margin-top: 28rpx;
}

.week-label {
  text-align: center;
  color: var(--text-soft);
  font-size: 20rpx;
  font-weight: 800;
}

.calendar-grid {
  margin-top: 14rpx;
}

.calendar-cell {
  min-width: 0;
  height: 76rpx;
}

.calendar-cell.is-blank {
  opacity: 0;
}

.calendar-dot {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4efea;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.calendar-cell.is-today .calendar-dot {
  box-shadow: inset 0 0 0 4rpx rgba(239, 124, 85, 0.44);
}

.calendar-cell.is-catchup-target .calendar-dot {
  box-shadow: inset 0 0 0 4rpx rgba(239, 124, 85, 0.64);
}

.calendar-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.legend-dot {
  display: inline-block;
  width: 22rpx;
  height: 22rpx;
  margin-right: 8rpx;
  border-radius: 8rpx;
  vertical-align: -2rpx;
  background: #f4efea;
}

.legend-dot.is-target {
  background: var(--accent);
}

.catchup {
  background: linear-gradient(135deg, #edfff9 0%, #fffdf2 100%);
}

.catchup-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.74);
}

.catchup-row.is-done {
  opacity: 0.62;
}

.catchup-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2f241f;
}

.catchup-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7d6f64;
}

.catchup-state {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: var(--growth);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.level-0 {
  background: #f4efea;
}

.level-1 {
  background: #cfead2;
}

.level-2 {
  background: #9fd7a7;
}

.level-3 {
  background: var(--growth);
  color: #fff;
}

.quote-card {
  background: linear-gradient(135deg, #f1ffed 0%, #fffef2 100%);
}

.quote-text {
  margin-top: 20rpx;
  font-size: 32rpx;
  line-height: 1.55;
  font-weight: 800;
  color: var(--text-main);
}

.quote-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  min-width: 220rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: var(--growth);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.total-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}
