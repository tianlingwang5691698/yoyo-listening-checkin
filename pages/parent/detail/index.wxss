.detail-hero {
  background: var(--surface);
}

.detail-row {
  margin-top: 18rpx;
  align-items: center;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.detail-copy {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.detail-time-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.detail-time-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.detail-time-value {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
}

.detail-empty-time {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.detail-side {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.detail-status,
.detail-progress {
  min-width: 120rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-status {
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-muted);
}

.detail-status.is-done {
  background: #edf9ef;
  color: #5f9d66;
}

.detail-progress {
  background: rgba(37, 35, 33, 0.04);
  color: var(--text-main);
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
