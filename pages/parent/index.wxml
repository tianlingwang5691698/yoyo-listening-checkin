<view class="page-shell parent-page">
  <view class="parent-hero product-hero">
    <view class="product-title type-page-title">日报</view>
    <view class="product-copy">{{child.nickname || '佑佑'}}</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
    </view>
  </view>

  <view class="report-card section-panel">
    <view class="row-between report-head">
      <view>
        <view class="section-title type-section-title">今日</view>
        <view class="section-copy">{{todayReport.completedCategories.length || 0}} 项 · {{todayReport.totalMinutes || 0}} 分钟</view>
      </view>
      <view class="detail-link" data-date="{{todayReport.date}}" bindtap="openDailyDetail">查看</view>
    </view>
    <block wx:for="{{todayReport.items}}" wx:key="category">
      <view class="report-item task-cell">
        <view>
          <view class="report-title">{{item.categoryLabel}}</view>
          <view class="report-copy">{{item.title}}</view>
        </view>
        <view class="report-progress {{item.completedToday ? 'is-done' : ''}}">{{item.playCount}} / {{item.repeatTarget}}</view>
      </view>
    </block>
  </view>

  <view class="trend-card section-panel">
    <view class="section-title type-section-title">最近 7 天</view>
    <block wx:for="{{recentReports}}" wx:key="reportId">
      <view class="trend-row task-cell is-link" data-date="{{item.date}}" bindtap="openDailyDetail">
        <view>
          <view class="trend-date">{{item.dateLabel}}</view>
          <view class="trend-copy">{{item.completedCategories.length ? '完成 ' + item.completedCategories.length + ' 项' : '无记录'}}</view>
        </view>
        <view class="trend-side">
          <view class="trend-badge">{{item.totalMinutes}} 分钟</view>
          <view class="trend-arrow">›</view>
        </view>
      </view>
    </block>
  </view>
</view>
