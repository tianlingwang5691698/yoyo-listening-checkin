.parent-hero {
  background: var(--surface);
}

.report-head {
  align-items: flex-start;
}

.report-item,
.trend-row {
  margin-top: 18rpx;
}

.report-title,
.trend-date {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.report-copy,
.trend-copy {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.report-progress,
.trend-badge {
  flex-shrink: 0;
  min-width: 112rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 700;
}

.report-progress.is-done {
  background: #edf9ef;
  color: #5f9d66;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
