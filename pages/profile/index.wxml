<view class="page-shell profile-page">
  <view class="profile-hero card">
    <view class="avatar">{{child.avatarText}}</view>
    <view class="profile-name">{{child.nickname}}</view>
    <view class="profile-copy">当前阶段：{{level.name}} · 已完成 {{child.completedDays}} 天</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
    </view>
    <view class="option-tag">{{syncMode === 'cloud' ? '家庭共享已接通' : '云同步异常'}}</view>
    <view class="identity-note">{{syncMode === 'cloud' ? '当前微信会自动识别家庭身份，并进入同一份孩子档案。' : '当前无法读取云端家庭档案，请先修复云函数后再继续使用。'}}</view>
  </view>

  <view class="option card">
    <view class="option-title">家庭共享</view>
    <view class="option-copy">家庭名：{{family.name}} · 当前身份：{{currentMember.displayName}}。弟弟、弟媳和你用各自微信打开后，通过邀请码加入，就能跨网络看同一个孩子 {{child.nickname}} 的进度。</view>
    <button class="button-primary mini-button" bindtap="openFamilyPage">打开家庭页</button>
  </view>

  <view class="option card">
    <view class="option-title">家长日报</view>
    <view class="option-copy">订阅消息做提醒，内页保留完整日报。家长页里可以看到 {{child.nickname}} 今天听了什么、完成了几遍、最近 7 天有没有稳住。</view>
    <button class="button-primary mini-button" bindtap="openParentPage">打开家长页</button>
  </view>

  <view class="option card">
    <view class="option-title">登录方式</view>
    <view class="option-copy">这版不做账号密码注册，直接用微信身份自动登录。每个家长都有自己的身份，同一个家庭共享同一个孩子的学习记录。</view>
    <view class="option-tag">WECHAT AUTO LOGIN</view>
  </view>

  <view class="option card">
    <view class="option-title">订阅状态</view>
    <view class="option-copy">{{subscriptionPreference.dailyReportEnabled ? '已开启每日报告提醒。家长完成后会收到摘要提醒。' : '还没开启每日报告提醒，可以到家长页里授权。'}}</view>
    <view class="option-tag">{{subscriptionPreference.dailyReportEnabled ? 'REPORTS ON' : 'REPORTS OFF'}}</view>
  </view>
</view>
