<view class="page-shell profile-page">
  <view class="profile-hero product-hero">
    <view class="profile-name-row">
      <input class="profile-name-input" placeholder="孩子昵称" value="{{childNicknameInput}}" bindinput="handleChildNicknameInput" />
      <button class="name-action" bindtap="saveChildProfile">✓</button>
    </view>
    <view class="profile-id-row">
      <view class="profile-id {{childCodeReady ? '' : 'is-pending'}}">ID {{childCodeText}}</view>
      <button wx:if="{{childCodeReady}}" class="id-copy" bindtap="copyChildCode">复制</button>
    </view>
    <view class="product-copy">{{dailyEncouragement.english}}</view>
    <view class="profile-cn">{{dailyEncouragement.chinese}}</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
    </view>
  </view>

  <view class="profile-list section-panel">
    <view class="profile-row" bindtap="openParentPage">
      <view>
        <view class="row-title">日报</view>
        <view class="row-copy">{{subscriptionPreference.dailyReportEnabled ? '提醒已开' : '查看打卡'}}</view>
      </view>
      <view class="row-arrow">›</view>
    </view>
    <view class="profile-row" bindtap="openFamilyPage">
      <view>
        <view class="row-title">家庭</view>
        <view class="row-copy">{{syncMode === 'cloud' ? '已接通' : '待同步'}}</view>
      </view>
      <view class="row-arrow">›</view>
    </view>
  </view>
</view>
