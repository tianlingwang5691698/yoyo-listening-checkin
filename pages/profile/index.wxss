.profile-hero {
  background:
    radial-gradient(circle at 86% 12%, rgba(102, 185, 133, 0.16), transparent 28%),
    linear-gradient(135deg, #fff8ee 0%, #fffdf8 100%);
}

.child-label {
  display: inline-flex;
  max-width: 100%;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
  color: var(--accent-deep);
  font-size: 23rpx;
  font-weight: 800;
}

.identity-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.identity-card {
  background: rgba(255, 255, 255, 0.72);
}

.identity-label {
  color: var(--text-muted);
  font-size: 22rpx;
}

.identity-value {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: var(--text-main);
}

.identity-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.identity-note {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.7;
  color: #8c7e72;
}

.option-head {
  align-items: flex-start;
}

.option-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2f241f;
}

.option-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8c7e72;
}

.option-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #edf9ef;
  color: #5f9d66;
  font-size: 22rpx;
  font-weight: 700;
}

.mini-button {
  margin-top: 24rpx;
  min-height: 82rpx;
  font-size: 26rpx;
}
