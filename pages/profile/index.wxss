.profile-hero {
  background: var(--surface);
}

.profile-name {
  color: var(--text-main);
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
  text-align: center;
}

.profile-cn {
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.5;
  text-align: center;
}

.product-copy {
  text-align: center;
}

.profile-list {
  margin-top: 24rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.profile-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.profile-row:last-child {
  border-bottom: none;
}

.action-row {
  align-items: flex-start;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-title {
  color: var(--text-main);
  font-size: 29rpx;
  font-weight: 700;
}

.row-copy {
  margin-top: 8rpx;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  color: var(--text-muted);
  font-size: 22rpx;
}

.row-copy.is-pending {
  color: var(--text-muted);
}

.profile-input {
  margin-top: 8rpx;
  width: 100%;
  min-height: 54rpx;
  color: var(--text-main);
  font-size: 25rpx;
}

.row-action {
  width: 112rpx;
  height: 60rpx;
  min-width: 112rpx;
  min-height: 60rpx;
  margin: 43rpx 0 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 23rpx;
  line-height: 60rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-action::after {
  border: none;
}

.row-arrow {
  color: var(--accent);
  font-size: 34rpx;
  line-height: 1;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
