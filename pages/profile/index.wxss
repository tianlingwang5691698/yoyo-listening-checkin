.profile-hero {
  background: var(--surface);
}

.profile-name {
  color: var(--text-main);
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
}

.profile-cn {
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.5;
}

.identity-code {
  margin-top: 24rpx;
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}

.code-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.code-label {
  color: var(--text-muted);
  font-size: 23rpx;
  font-weight: 700;
}

.child-code {
  margin-top: 28rpx;
  color: var(--text-strong);
  font-size: 78rpx;
  line-height: 1;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.child-code.is-pending {
  color: var(--text-muted);
  font-size: 48rpx;
}

.mini-button {
  margin-top: 28rpx;
  min-height: 78rpx;
  font-size: 25rpx;
}

.profile-list {
  margin-top: 24rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.profile-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.profile-row:last-child {
  border-bottom: none;
}

.edit-row {
  align-items: center;
}

.row-title {
  color: var(--text-main);
  font-size: 29rpx;
  font-weight: 700;
}

.row-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.profile-input {
  margin-top: 8rpx;
  width: 360rpx;
  min-height: 54rpx;
  color: var(--text-main);
  font-size: 25rpx;
}

.row-action {
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-action::after {
  border: none;
}

.row-arrow {
  color: var(--accent);
  font-size: 34rpx;
  line-height: 1;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
