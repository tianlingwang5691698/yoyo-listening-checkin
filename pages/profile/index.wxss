.profile-hero {
  background: var(--surface);
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.profile-name-input {
  flex: 1;
  min-width: 0;
  min-height: 58rpx;
  color: var(--text-main);
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
}

.name-action {
  width: 62rpx;
  height: 62rpx;
  min-width: 62rpx;
  min-height: 62rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 27rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.name-action::after {
  border: none;
}

.profile-id-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 10rpx;
}

.profile-id {
  color: var(--text-muted);
  font-size: 23rpx;
  font-weight: 700;
}

.profile-id.is-pending {
  color: var(--text-muted);
  font-weight: 600;
}

.id-copy {
  min-width: 82rpx;
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 21rpx;
  font-weight: 700;
}

.id-copy::after {
  border: none;
}

.profile-cn {
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.5;
}

.profile-list {
  margin-top: 24rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.profile-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.profile-row:last-child {
  border-bottom: none;
}

.row-title {
  color: var(--text-main);
  font-size: 29rpx;
  font-weight: 700;
}

.row-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.row-arrow {
  color: var(--accent);
  font-size: 34rpx;
  line-height: 1;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
