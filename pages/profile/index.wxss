.profile-hero {
  background: var(--surface);
}

.child-label {
  display: inline-flex;
  max-width: 100%;
  min-height: 54rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 23rpx;
  font-weight: 700;
}

.profile-cn {
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.5;
}

.identity-code,
.nickname-card {
  margin-top: 24rpx;
}

.child-code {
  margin-top: 24rpx;
  color: var(--text-strong);
  font-size: 64rpx;
  line-height: 1;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.profile-input {
  margin-top: 22rpx;
}

.identity-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.identity-card {
  background: rgba(255, 255, 255, 0.72);
}

.identity-label {
  color: var(--text-muted);
  font-size: 22rpx;
}

.identity-value {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.identity-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.option-head {
  align-items: flex-start;
}

.option-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.option-copy {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.55;
  color: var(--text-muted);
}

.mini-button {
  margin-top: 24rpx;
  min-height: 82rpx;
  font-size: 26rpx;
}
