.profile-hero,
.option {
  padding: 30rpx;
}

.profile-hero {
  text-align: center;
  background: linear-gradient(135deg, #fff0e3 0%, #fff8f0 100%);
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  margin: 0 auto;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  color: #ef7c55;
  font-size: 40rpx;
  font-weight: 800;
}

.profile-copy {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f6d61;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.identity-note {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.7;
  color: #8c7e72;
}

.option {
  margin-top: 22rpx;
}

.option-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f241f;
}

.option-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8c7e72;
}

.option-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #edf9ef;
  color: #5f9d66;
  font-size: 22rpx;
  font-weight: 700;
}

.mini-button {
  margin-top: 24rpx;
  min-height: 82rpx;
  font-size: 26rpx;
}
