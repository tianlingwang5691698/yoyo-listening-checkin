.level-header {
  padding: 70rpx 20rpx 28rpx;
}

.level-subtitle {
  margin-top: 10rpx;
}

.level-tabs {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.level-tab {
  min-height: 62rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 23rpx;
  font-weight: 600;
}

.level-tab.is-active {
  background: var(--text-strong);
  color: #fffdfa;
}

.level-tab.is-disabled {
  opacity: 0.38;
}

.stage-list {
  margin-top: 0;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
}

.stage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.stage-row:last-child {
  border-bottom: none;
}

.stage-row.is-active {
  background: rgba(255, 244, 235, 0.74);
}

.stage-row.is-disabled {
  opacity: 0.5;
}

.stage-row-title {
  color: var(--text-main);
  font-size: 27rpx;
  font-weight: 700;
}

.stage-row-meta {
  margin-top: 8rpx;
}

.stage-row-state {
  flex-shrink: 0;
  min-width: 56rpx;
  color: var(--accent-deep);
  text-align: right;
  font-size: 22rpx;
  font-weight: 700;
}

.stage-debug {
  padding: 20rpx 28rpx 24rpx;
  color: var(--text-muted);
}
