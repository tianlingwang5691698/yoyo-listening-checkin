.level-header {
  padding: 70rpx 20rpx 28rpx;
}

.level-subtitle {
  margin-top: 10rpx;
}

.level-tabs {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.level-tab {
  min-height: 62rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 23rpx;
  font-weight: 600;
}

.level-tab.is-active {
  background: var(--text-strong);
  color: #fffdfa;
}

.level-tab.is-disabled {
  opacity: 0.38;
}

.stage-card {
  padding: 30rpx 28rpx;
  background: rgba(255, 255, 255, 0.84);
}

.stage-level {
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 600;
}

.stage-title {
  margin-top: 12rpx;
  color: var(--text-strong);
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
}

.program-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 30rpx 28rpx;
  background: rgba(255, 255, 255, 0.84);
}

.program-row.is-disabled {
  opacity: 0.48;
}

.program-name {
  color: var(--text-strong);
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.program-meta {
  margin-top: 10rpx;
}

.program-state {
  flex-shrink: 0;
  min-width: 52rpx;
  color: var(--accent-deep);
  text-align: right;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.program-state.is-done,
.program-state.is-waiting {
  color: var(--text-muted);
  font-size: 22rpx;
}
