.level-hero {
  background: var(--surface);
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.level-kpis {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.unit-block {
  margin-top: 24rpx;
}

.unit-block-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: var(--text-main);
}

.unit-count {
  color: #74b87c;
  font-size: 26rpx;
  font-weight: 700;
}

.lesson-row {
  margin-top: 22rpx;
}

.lesson-order {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff4e8;
  color: #d96a45;
  font-size: 24rpx;
  font-weight: 800;
}

.lesson-body {
  flex: 1;
  min-width: 0;
}

.lesson-title {
  font-size: 29rpx;
  font-weight: 700;
  color: #2f241f;
}

.lesson-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c7e72;
}

.lesson-tag {
  min-width: 92rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
}

.done {
  background: #edf9ef;
  color: #5f9d66;
}

.ready {
  background: #fff2e7;
  color: #d96a45;
}

.locked {
  background: #f4efea;
  color: #8c7e72;
}

.is-disabled {
  opacity: 0.68;
}
