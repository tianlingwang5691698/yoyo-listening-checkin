<view class="page-shell level-page">
  <view class="level-header">
    <view class="type-page-title">音频</view>
    <view class="type-caption level-subtitle">{{currentStage.dayText}}</view>
  </view>

  <view class="level-tabs">
    <block wx:for="{{levelTabs}}" wx:key="levelId">
      <view class="level-tab {{item.enabled ? 'is-active' : 'is-disabled'}}" data-enabled="{{item.enabled}}" bindtap="chooseLevel">
        {{item.levelId}}
      </view>
    </block>
  </view>

  <view class="stage-card card">
    <view class="stage-level">{{currentStage.levelId}}</view>
    <view class="stage-title">{{currentStage.label}}</view>
  </view>

  <block wx:for="{{programEntries}}" wx:key="category">
    <view class="program-row card {{item.disabled ? 'is-disabled' : ''}}" data-category="{{item.category}}" data-task-id="{{item.taskId}}" data-disabled="{{item.disabled}}" bindtap="openCategory">
      <view>
        <view class="program-name">{{item.categoryLabel}}</view>
        <view class="program-meta type-caption">{{item.title}} · {{item.textType}}</view>
      </view>
      <view class="program-state {{item.stateClass}}">{{item.stateText}}</view>
    </view>
  </block>
</view>
