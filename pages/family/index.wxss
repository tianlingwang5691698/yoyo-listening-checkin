.family-hero {
  background: var(--surface);
}

.family-list {
  margin-top: 24rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.family-row,
.member-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.family-row:last-child,
.member-row:last-child {
  border-bottom: none;
}

.input-row {
  align-items: center;
}

.row-title,
.member-name {
  color: var(--text-main);
  font-size: 29rpx;
  font-weight: 700;
}

.row-copy,
.member-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.family-input {
  width: 360rpx;
  min-height: 54rpx;
  margin-top: 8rpx;
  color: var(--text-main);
  font-size: 25rpx;
}

.row-action {
  width: 112rpx;
  height: 60rpx;
  min-width: 112rpx;
  min-height: 60rpx;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-action::after {
  border: none;
}

.member-card {
  margin-top: 24rpx;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
