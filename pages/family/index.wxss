.family-hero {
  background:
    radial-gradient(circle at 86% 14%, rgba(102, 185, 133, 0.16), transparent 28%),
    linear-gradient(135deg, #fff8ee 0%, #fffdf8 100%);
}

.family-head,
.family-section-head {
  align-items: flex-start;
}

.family-eyebrow {
  color: #ad7f55;
  font-size: 20rpx;
  font-weight: 800;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}

.family-status-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.family-status {
  background: rgba(255, 255, 255, 0.66);
}

.login-title {
  font-size: 22rpx;
  color: #8c7e72;
}

.login-copy {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2f241f;
}

.status-copy {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.invite-box {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.72);
}

.invite-label {
  font-size: 22rpx;
  color: #8c7e72;
}

.invite-code {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #2f241f;
}

.child-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  min-height: 74rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff5ea;
  color: #d96a45;
  font-size: 23rpx;
  font-weight: 700;
}

.family-input {
  width: 100%;
  min-height: 88rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #fff7f0;
  color: #2f241f;
  font-size: 26rpx;
}

.button-primary {
  margin-top: 22rpx;
}

.reserve-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.reserve-item {
  min-width: 0;
}

.reserve-label {
  color: var(--text-muted);
  font-size: 22rpx;
}

.reserve-value {
  margin-top: 12rpx;
  color: var(--text-main);
  font-size: 26rpx;
  font-weight: 700;
  word-break: break-all;
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(84, 57, 45, 0.08);
}

.member-row:last-child {
  border-bottom: none;
}

.member-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f241f;
}

.member-copy {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8c7e72;
}

.member-state {
  flex-shrink: 0;
  min-width: 120rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #fff5ea;
  color: #d96a45;
  font-size: 22rpx;
  font-weight: 700;
}
