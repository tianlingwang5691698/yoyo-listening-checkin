.family-hero {
  background: var(--surface);
}

.family-list {
  margin-top: 24rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.family-list .section-title,
.member-card .section-title {
  margin-bottom: 8rpx;
}

.family-row,
.member-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(37, 35, 33, 0.08);
}

.family-row:last-child,
.member-row:last-child {
  border-bottom: none;
}

.action-row {
  align-items: flex-start;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-title,
.member-name {
  color: var(--text-main);
  font-size: 29rpx;
  font-weight: 700;
}

.row-copy,
.member-copy {
  margin-top: 8rpx;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  color: var(--text-muted);
  font-size: 22rpx;
}

.family-input {
  width: 100%;
  min-height: 54rpx;
  margin-top: 8rpx;
  color: var(--text-main);
  font-size: 25rpx;
}

.row-action {
  width: 112rpx;
  height: 60rpx;
  min-width: 112rpx;
  min-height: 60rpx;
  margin: 43rpx 0 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(37, 35, 33, 0.06);
  color: var(--text-main);
  font-size: 23rpx;
  line-height: 60rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-action::after {
  border: none;
}

.row-action-ghost {
  background: transparent;
  color: transparent;
}

.row-action-wide {
  width: 128rpx;
  min-width: 128rpx;
}

.row-action-warn {
  background: rgba(180, 94, 64, 0.1);
  color: #b45e40;
}

.row-action.is-disabled {
  opacity: 0.5;
}

.member-card {
  margin-top: 24rpx;
}

.member-role {
  flex-shrink: 0;
  align-self: center;
  color: var(--text-muted);
  text-align: right;
}

.sync-debug {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
  background: rgba(255, 255, 255, 0.62);
  color: #6f6258;
}

.sync-debug.is-cloud {
  background: rgba(233, 248, 235, 0.84);
  color: #44734b;
}

.sync-debug.is-local {
  background: rgba(255, 241, 234, 0.9);
  color: #b45e40;
}
