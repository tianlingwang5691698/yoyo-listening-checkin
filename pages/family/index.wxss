.family-hero,
.join-card,
.member-card {
  padding: 30rpx;
}

.family-hero {
  background: linear-gradient(135deg, #fff1e5 0%, #fff9f2 100%);
}

.invite-box {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
}

.family-login-note {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.58);
}

.login-title {
  font-size: 22rpx;
  color: #8c7e72;
}

.login-copy {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2f241f;
}

.invite-label {
  font-size: 22rpx;
  color: #8c7e72;
}

.invite-code {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #2f241f;
}

.join-card,
.child-card,
.member-card {
  margin-top: 24rpx;
}

.child-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  min-height: 74rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff5ea;
  color: #d96a45;
  font-size: 23rpx;
  font-weight: 700;
}

.family-input {
  width: 100%;
  min-height: 88rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #fff7f0;
  color: #2f241f;
  font-size: 26rpx;
}

.button-primary {
  margin-top: 22rpx;
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(84, 57, 45, 0.08);
}

.member-row:last-child {
  border-bottom: none;
}

.member-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f241f;
}

.member-copy {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8c7e72;
}

.member-state {
  flex-shrink: 0;
  min-width: 120rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #fff5ea;
  color: #d96a45;
  font-size: 22rpx;
  font-weight: 700;
}
