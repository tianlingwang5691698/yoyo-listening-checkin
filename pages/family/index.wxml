<view class="page-shell family-page">
  <view class="family-hero card">
    <view class="row-between family-head">
      <view>
        <view class="family-eyebrow">FAMILY</view>
        <view class="family-title">家庭管理中心</view>
        <view class="section-copy">{{family.name || '我的家庭'}} · {{child.nickname || '佑佑'}}</view>
        <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
          {{syncDebug.text}}
        </view>
      </view>
      <view class="status-badge {{syncMode === 'cloud' ? '' : 'is-warn'}}">{{syncMode === 'cloud' ? '共享中' : '异常'}}</view>
    </view>

    <view class="family-status-grid">
      <view class="family-status card-subtle">
        <view class="login-title">当前身份</view>
        <view class="login-copy">{{currentMember.displayName || '微信用户'}}</view>
        <view class="status-copy">{{currentMember.role === 'owner' ? '管理员' : '家长成员'}}</view>
      </view>
      <view class="family-status card-subtle">
        <view class="login-title">订阅状态</view>
        <view class="login-copy">{{subscriptionPreference.dailyReportEnabled ? '日报提醒开' : '日报提醒关'}}</view>
        <view class="status-copy">家长日报</view>
      </view>
    </view>
  </view>

  <view class="child-card card">
    <view class="row-between family-section-head">
      <view>
        <view class="section-title">孩子档案</view>
        <view class="section-copy">当前一个家庭对应一个孩子档案。</view>
      </view>
      <view class="pill">{{child.currentLevel || 'A1'}}</view>
    </view>
    <input class="family-input form-input" placeholder="输入孩子昵称，例如 乐乐 / Amy" value="{{childNicknameInput}}" bindinput="handleChildNicknameInput" />
    <button class="button-primary" bindtap="saveChildProfile">保存孩子昵称</button>
  </view>

  <view class="invite-card card">
    <view class="row-between family-section-head">
      <view>
        <view class="section-title">家庭邀请码</view>
        <view class="section-copy">其他家长输入后加入同一份记录。</view>
      </view>
      <view class="status-badge">可刷新</view>
    </view>
    <view class="invite-box">
      <view class="invite-label">邀请码</view>
      <view class="invite-code">{{family.inviteCode || '待生成'}}</view>
    </view>
    <button class="button-primary" bindtap="refreshInviteCode">刷新邀请码</button>
  </view>

  <view class="reserve-card card">
    <view class="section-title">后续身份码</view>
    <view class="reserve-grid">
      <view class="reserve-item card-subtle">
        <view class="reserve-label">孩子 ID</view>
        <view class="reserve-value">{{child.childId || '后续开放'}}</view>
      </view>
      <view class="reserve-item card-subtle">
        <view class="reserve-label">家长邀请码</view>
        <view class="reserve-value">后续开放</view>
      </view>
    </view>
  </view>

  <view class="join-card card">
    <view class="section-title">加入家庭</view>
    <view class="section-copy">输入邀请码，加入同一个孩子档案。</view>
    <input class="family-input form-input" placeholder="输入邀请码" value="{{inviteInput}}" bindinput="handleInviteInput" />
    <input class="family-input form-input" placeholder="输入称呼，例如 妈妈 / 奶奶 / 老师" value="{{joinName}}" bindinput="handleJoinNameInput" />
    <button class="button-primary" bindtap="joinFamily">加入家庭</button>
  </view>

  <view class="member-card card">
    <view class="row-between family-section-head">
      <view>
        <view class="section-title">当前家庭成员</view>
        <view class="section-copy">共享任务进度、日报和连续天数。</view>
      </view>
      <view class="pill">{{members.length || 0}} 人</view>
    </view>
    <block wx:for="{{members}}" wx:key="memberId">
      <view class="member-row">
        <view>
          <view class="member-name">{{item.displayName}}</view>
          <view class="member-copy">{{item.role === 'owner' ? '管理员' : '家长成员'}}</view>
        </view>
        <view class="member-state">{{item.subscriptionEnabled ? '提醒开' : '提醒关'}}</view>
      </view>
    </block>
  </view>
</view>
