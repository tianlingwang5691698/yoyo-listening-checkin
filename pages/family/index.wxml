<view class="page-shell family-page">
  <view class="family-hero product-hero">
    <view class="product-title type-page-title">家庭</view>
    <view class="product-copy">{{syncMode === 'cloud' ? '已接通' : '待同步'}}</view>
    <view class="sync-debug {{syncMode === 'cloud' ? 'is-cloud' : 'is-local'}}" wx:if="{{showCloudDebug && syncDebug && syncDebug.show}}">
      {{syncDebug.text}}
    </view>
  </view>

  <view class="family-list section-panel">
    <view class="family-row">
      <view>
        <view class="row-title">ID</view>
        <view class="row-copy">{{child.childLoginCode || '待同步'}}</view>
      </view>
      <button class="row-action" bindtap="copyChildCode">⧉</button>
    </view>
    <view class="family-row input-row">
      <view>
        <view class="row-title">加入</view>
        <input class="family-input" type="number" maxlength="6" placeholder="孩子 ID" value="{{childCodeInput}}" bindinput="handleChildCodeInput" />
        <input class="family-input" placeholder="称呼" value="{{joinName}}" bindinput="handleJoinNameInput" />
      </view>
      <button class="row-action" bindtap="joinFamilyByChildCode">✓</button>
    </view>
  </view>

  <view class="member-card section-panel">
    <view class="section-title">成员</view>
    <block wx:for="{{members}}" wx:key="memberId">
      <view class="member-row">
        <view>
          <view class="member-name">{{item.displayName}}</view>
          <view class="member-copy">{{item.role === 'owner' ? '管理员' : '家长'}}</view>
        </view>
      </view>
    </block>
  </view>
</view>
