.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: calc(104rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  background: #fbf7ef;
  border-top: 1rpx solid rgba(37, 35, 33, 0.08);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.tabbar-item {
  min-width: 0;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8c7e72;
  font-size: 22rpx;
  font-weight: 600;
}

.tabbar-item.is-active {
  color: #2f2b27;
}

.tabbar-text {
  line-height: 1;
}
