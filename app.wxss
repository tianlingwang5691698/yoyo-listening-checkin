page {
  --bg-cream: #fff8ee;
  --surface: #fffdf8;
  --surface-soft: #fff4dd;
  --text-main: #2f241f;
  --text-muted: #8c7e72;
  --accent: #ef7c55;
  --accent-deep: #d96a45;
  --reward: #74b87c;
  --reward-soft: #edf9ef;
  --border-soft: rgba(84, 57, 45, 0.08);
  --shadow-soft: 0 16rpx 48rpx rgba(94, 64, 47, 0.08);
  --radius-xl: 36rpx;
  --radius-lg: 28rpx;
  --radius-md: 20rpx;
  background: var(--bg-cream);
  color: var(--text-main);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 214, 173, 0.58), transparent 34%),
    radial-gradient(circle at top right, rgba(255, 238, 205, 0.88), transparent 30%),
    linear-gradient(180deg, #fff9f0 0%, #fff7eb 100%);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.section-copy {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(239, 124, 85, 0.12);
  color: var(--accent-deep);
  font-size: 22rpx;
}

.card {
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-soft);
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 96rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff9864 0%, #ef7c55 100%);
  color: #fffaf6;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(239, 124, 85, 0.26);
}

.button-primary[disabled] {
  opacity: 0.55;
}

.button-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: #fff5ea;
  color: var(--accent-deep);
  font-size: 28rpx;
  font-weight: 600;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: var(--text-muted);
}
