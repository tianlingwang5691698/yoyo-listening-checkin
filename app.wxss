page {
  --bg-cream: #fbf7ef;
  --bg-warm: #f7f2e9;
  --surface: #fffdfa;
  --surface-soft: #f6f0e7;
  --surface-subtle: #fbf8f2;
  --text-main: #252321;
  --text-strong: #181715;
  --text-muted: #85807a;
  --text-soft: #aaa49c;
  --accent: #ef7c55;
  --accent-deep: #d96a45;
  --accent-soft: #fff0e7;
  --growth: #66b985;
  --growth-deep: #428f62;
  --growth-soft: #edf9ef;
  --reward: #74b87c;
  --reward-soft: #edf9ef;
  --warning: #d98f45;
  --warning-soft: #fff5e7;
  --danger: #c85f50;
  --danger-soft: #fff0ee;
  --border-soft: rgba(84, 57, 45, 0.08);
  --border-strong: rgba(84, 57, 45, 0.14);
  --shadow-soft: 0 8rpx 24rpx rgba(40, 36, 30, 0.04);
  --shadow-card: 0 10rpx 32rpx rgba(40, 36, 30, 0.06);
  --radius-xl: 28rpx;
  --radius-lg: 24rpx;
  --radius-md: 20rpx;
  --radius-sm: 14rpx;
  --space-page-x: 24rpx;
  --space-card: 30rpx;
  background: var(--bg-cream);
  color: var(--text-main);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
navigator,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1.2;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx var(--space-page-x) 40rpx;
  background: var(--bg-cream);
}

.page-container {
  min-height: 100vh;
  padding: 28rpx var(--space-page-x) 40rpx;
  background: var(--bg-cream);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

.section-copy {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f2eee7;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
}

.card {
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.card-main {
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.card-subtle {
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.62);
}

.data-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.data-cell {
  min-width: 0;
  padding: 22rpx 10rpx;
  border-radius: var(--radius-lg);
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
}

.data-value {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  color: var(--text-strong);
}

.data-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--text-muted);
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 96rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: #fffaf6;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(239, 124, 85, 0.22);
}

.button-primary[disabled] {
  opacity: 0.55;
}

.button-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: #fff5ea;
  color: var(--accent-deep);
  font-size: 28rpx;
  font-weight: 600;
}

.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: var(--growth-soft);
  color: var(--growth-deep);
  font-size: 28rpx;
  font-weight: 700;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-lg);
  background: #fff8f0;
  color: var(--text-main);
  font-size: 26rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f2eee7;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.status-badge.is-muted {
  background: #f4efea;
  color: var(--text-muted);
}

.status-badge.is-warn {
  background: var(--warning-soft);
  color: var(--warning);
}

.empty-state,
.error-state {
  padding: 28rpx;
  border-radius: var(--radius-lg);
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.error-state {
  background: var(--danger-soft);
  color: var(--danger);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.muted {
  color: var(--text-muted);
}

.type-brand {
  color: var(--text-strong);
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 700;
}

.type-page-title {
  color: var(--text-strong);
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
}

.type-card-title {
  color: var(--text-strong);
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 700;
}

.type-section-title {
  color: var(--text-main);
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.type-body {
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.55;
  font-weight: 400;
}

.type-caption {
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 500;
}

.text-strong {
  color: var(--text-strong);
}

.text-muted {
  color: var(--text-muted);
}

.product-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx;
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.product-eyebrow {
  color: #ad7f55;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.product-title {
  margin-top: 12rpx;
  color: var(--text-strong);
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
}

.product-copy {
  margin-top: 14rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1.65;
}

.section-panel {
  margin-top: 24rpx;
  padding: var(--space-card);
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.form-panel {
  margin-top: 24rpx;
  padding: var(--space-card);
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.program-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.program-card {
  position: relative;
  overflow: hidden;
  min-width: 0;
  padding: 26rpx;
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border-soft);
  background: rgba(255, 255, 255, 0.74);
}

.program-card.tone-peppa {
  background: var(--surface);
}

.program-card.tone-unlock {
  background: var(--surface);
}

.program-card.tone-song {
  background: var(--surface);
}

.task-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.7);
}

.stat-tile {
  min-width: 0;
  padding: 24rpx 18rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid var(--border-soft);
}

.stat-tile-value {
  color: var(--text-strong);
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 900;
}

.stat-tile-label {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.35;
}

.progress-rail {
  width: 100%;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(84, 57, 45, 0.1);
}

.progress-rail-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--growth) 0%, var(--accent) 100%);
}

.action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
