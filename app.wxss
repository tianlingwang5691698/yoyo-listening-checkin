page {
  --bg-cream: #fff8ee;
  --bg-warm: #fff6e8;
  --surface: #fffdf8;
  --surface-soft: #fff4dd;
  --surface-subtle: #fff9f1;
  --text-main: #2f241f;
  --text-strong: #201916;
  --text-muted: #8c7e72;
  --text-soft: #a6978b;
  --accent: #ef7c55;
  --accent-deep: #d96a45;
  --accent-soft: #fff0e7;
  --growth: #66b985;
  --growth-deep: #428f62;
  --growth-soft: #edf9ef;
  --reward: #74b87c;
  --reward-soft: #edf9ef;
  --warning: #d98f45;
  --warning-soft: #fff5e7;
  --danger: #c85f50;
  --danger-soft: #fff0ee;
  --border-soft: rgba(84, 57, 45, 0.08);
  --border-strong: rgba(84, 57, 45, 0.14);
  --shadow-soft: 0 16rpx 48rpx rgba(94, 64, 47, 0.08);
  --shadow-card: 0 20rpx 56rpx rgba(94, 64, 47, 0.1);
  --radius-xl: 36rpx;
  --radius-lg: 28rpx;
  --radius-md: 20rpx;
  --radius-sm: 14rpx;
  --space-page-x: 24rpx;
  --space-card: 30rpx;
  background: var(--bg-cream);
  color: var(--text-main);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
navigator,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1.2;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx var(--space-page-x) 40rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 226, 189, 0.54), transparent 30%),
    radial-gradient(circle at top right, rgba(235, 249, 235, 0.68), transparent 28%),
    linear-gradient(180deg, #fff9f0 0%, #fff7eb 100%);
}

.page-container {
  min-height: 100vh;
  padding: 28rpx var(--space-page-x) 40rpx;
  background: var(--bg-cream);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

.section-copy {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: var(--accent-deep);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
}

.card {
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.card-main {
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.card-subtle {
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.62);
}

.data-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.data-cell {
  min-width: 0;
  padding: 22rpx 10rpx;
  border-radius: var(--radius-lg);
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
}

.data-value {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  color: var(--text-strong);
}

.data-label {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--text-muted);
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 96rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff9864 0%, #ef7c55 100%);
  color: #fffaf6;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(239, 124, 85, 0.26);
}

.button-primary[disabled] {
  opacity: 0.55;
}

.button-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: #fff5ea;
  color: var(--accent-deep);
  font-size: 28rpx;
  font-weight: 600;
}

.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: var(--growth-soft);
  color: var(--growth-deep);
  font-size: 28rpx;
  font-weight: 700;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-lg);
  background: #fff8f0;
  color: var(--text-main);
  font-size: 26rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--growth-soft);
  color: var(--growth-deep);
  font-size: 22rpx;
  font-weight: 800;
}

.status-badge.is-muted {
  background: #f4efea;
  color: var(--text-muted);
}

.status-badge.is-warn {
  background: var(--warning-soft);
  color: var(--warning);
}

.empty-state,
.error-state {
  padding: 28rpx;
  border-radius: var(--radius-lg);
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.error-state {
  background: var(--danger-soft);
  color: var(--danger);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.muted {
  color: var(--text-muted);
}

.product-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx;
  border-radius: var(--radius-xl);
  background:
    radial-gradient(circle at 88% 14%, rgba(102, 185, 133, 0.16), transparent 28%),
    linear-gradient(135deg, #fff8ee 0%, #fffdf8 100%);
  box-shadow: var(--shadow-card);
}

.product-eyebrow {
  color: #ad7f55;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}

.product-title {
  margin-top: 12rpx;
  color: var(--text-main);
  font-size: 50rpx;
  line-height: 1.14;
  font-weight: 900;
}

.product-copy {
  margin-top: 14rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1.65;
}

.section-panel {
  margin-top: 24rpx;
  padding: var(--space-card);
  border-radius: var(--radius-xl);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.form-panel {
  margin-top: 24rpx;
  padding: var(--space-card);
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, #fffdf8 0%, #fff8f1 100%);
  box-shadow: var(--shadow-card);
}

.program-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.program-card {
  position: relative;
  overflow: hidden;
  min-width: 0;
  padding: 26rpx;
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border-soft);
  background: rgba(255, 255, 255, 0.74);
}

.program-card.tone-peppa {
  background: linear-gradient(135deg, #fff7ef 0%, #ffe7dc 100%);
}

.program-card.tone-unlock {
  background: linear-gradient(135deg, #fffdf8 0%, #eee7df 100%);
}

.program-card.tone-song {
  background: linear-gradient(135deg, #f7fffb 0%, #e6f7ef 100%);
}

.task-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.7);
}

.stat-tile {
  min-width: 0;
  padding: 24rpx 18rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid var(--border-soft);
}

.stat-tile-value {
  color: var(--text-strong);
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 900;
}

.stat-tile-label {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.35;
}

.progress-rail {
  width: 100%;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(84, 57, 45, 0.1);
}

.progress-rail-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--growth) 0%, var(--accent) 100%);
}

.action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
